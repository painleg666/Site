@code {
    private byte[]? selectedPhotoBytes;
    private string selectedPhotoContentType = "";
    private string selectedFileName = "";
    private string selectedFileSizeText = "";
    private string photoPreviewDataUrl = "";
    private string errorMessage = "";
    private bool isAnalyzing;
    private bool isDemoResult;
    private AiDamageResult? result;
    private bool showTechnicalJson;

    private const long MaxFileSize = 8 * 1024 * 1024;

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        ResetAnalysis(keepPhoto: false);

        var file = e.File;

        if (file is null)
        {
            errorMessage = "Фото не выбрано.";
            return;
        }

        if (file.Size > MaxFileSize)
        {
            errorMessage = "Файл слишком большой. Максимальный размер — 8 МБ.";
            return;
        }

        selectedFileName = file.Name;
        selectedFileSizeText = $"{file.Size / 1024.0 / 1024.0:0.00} МБ";
        selectedPhotoContentType = string.IsNullOrWhiteSpace(file.ContentType)
            ? "image/jpeg"
            : file.ContentType;

        try
        {
            await using var stream = file.OpenReadStream(MaxFileSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            selectedPhotoBytes = memoryStream.ToArray();
            var base64 = Convert.ToBase64String(selectedPhotoBytes);
            photoPreviewDataUrl = $"data:{selectedPhotoContentType};base64,{base64}";
        }
        catch
        {
            selectedPhotoBytes = null;
            photoPreviewDataUrl = "";
            errorMessage = "Не удалось загрузить фото для предпросмотра.";
        }
    }

    private async Task AnalyzePhotoGemini()
    {
        errorMessage = "";
        result = null;
        isDemoResult = false;

        if (selectedPhotoBytes is null || selectedPhotoBytes.Length == 0)
        {
            errorMessage = "Сначала загрузите фото повреждения.";
            return;
        }

        isAnalyzing = true;

        try
        {
            result = await GeminiDamageService.AnalyzeAsync(selectedPhotoBytes, selectedPhotoContentType);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isAnalyzing = false;
        }
    }

    private async Task AnalyzePhotoDemo()
    {
        errorMessage = "";
        result = null;
        isDemoResult = true;

        if (selectedPhotoBytes is null || selectedPhotoBytes.Length == 0)
        {
            errorMessage = "Сначала загрузите фото повреждения.";
            return;
        }

        isAnalyzing = true;

        try
        {
            await Task.Delay(900);
            result = CreateDemoResult(selectedFileName, selectedPhotoBytes.Length);
        }
        finally
        {
            isAnalyzing = false;
        }
    }

    private AiDamageResult CreateDemoResult(string fileName, long fileSize)
    {
        var lowerName = fileName.ToLowerInvariant();

        var detectedPart =
            lowerName.Contains("door") || lowerName.Contains("двер") ? "Передняя левая дверь" :
            lowerName.Contains("bumper") || lowerName.Contains("бампер") ? "Передний бампер" :
            lowerName.Contains("hood") || lowerName.Contains("капот") ? "Капот" :
            lowerName.Contains("light") || lowerName.Contains("фара") ? "Передняя фара" :
            "Передний бампер";

        var damageType =
            lowerName.Contains("dent") || lowerName.Contains("вмят") ? "Вмятина" :
            lowerName.Contains("crack") || lowerName.Contains("трещ") ? "Трещина" :
            lowerName.Contains("chip") || lowerName.Contains("скол") ? "Скол" :
            "Царапина";

        var repairType = damageType switch
        {
            "Царапина" => "Покраска",
            "Скол" => detectedPart.Contains("фара", StringComparison.OrdinalIgnoreCase) ? "Замена" : "Покраска",
            "Вмятина" => "Ремонт",
            "Трещина" => detectedPart.Contains("фара", StringComparison.OrdinalIgnoreCase) ? "Замена" : "Ремонт",
            _ => "Ремонт"
        };

        var damageLevel = damageType switch
        {
            "Царапина" => "Лёгкое",
            "Скол" => "Лёгкое",
            "Вмятина" => "Среднее",
            "Трещина" => "Среднее",
            _ => "Среднее"
        };

        var confidence = 0.72 + (fileSize % 17) / 100.0;

        if (confidence < 0.68)
            confidence = 0.68;

        if (confidence > 0.89)
            confidence = 0.89;

        var demoItem = new AiDamageItem
        {
            DetectedPart = detectedPart,
            DamageType = damageType,
            RepairType = repairType,
            DamageLevel = damageLevel,
            Confidence = confidence,
            NeedsHumanReview = true,
            Comment = $"На фото предположительно обнаружено повреждение типа “{damageType}” на детали “{detectedPart}”. Это демонстрационный результат."
        };

        demoItem.EstimatedCost = CalculateDemoCost(demoItem);

        var demoResult = new AiDamageResult
        {
            DetectedPart = demoItem.DetectedPart,
            DamageType = demoItem.DamageType,
            RepairType = demoItem.RepairType,
            DamageLevel = demoItem.DamageLevel,
            Confidence = demoItem.Confidence,
            EstimatedCost = demoItem.EstimatedCost,
            IsCarDamagePhoto = true,
            NeedsHumanReview = true,
            Comment = "Демонстрационная AI-подсказка сформирована локально.",
            Items = new List<AiDamageItem> { demoItem }
        };

        return demoResult;
    }

    private static decimal CalculateDemoCost(AiDamageItem item)
    {
        var basePrice = item.DetectedPart switch
        {
            "Передний бампер" => 9000m,
            "Капот" => 12000m,
            "Передняя левая дверь" => 10000m,
            "Передняя фара" => 18000m,
            _ => 9000m
        };

        var levelMultiplier = item.DamageLevel switch
        {
            "Лёгкое" => 1.0m,
            "Среднее" => 1.4m,
            "Сильное" => 1.9m,
            _ => 1.0m
        };

        return Math.Round(basePrice * levelMultiplier, 0);
    }


    private void ApplyAiResultToRequest()
    {
        errorMessage = "";

        if (result is null || result.Items.Count == 0)
        {
            errorMessage = "Нет AI-результата для применения.";
            return;
        }

        PendingAiDamageState.SetItems(result.Items);

        Navigation.NavigateTo("/repair-requests?ai=1");
    }

    private string GetResultJson()
    {
        if (result is null)
            return "";

        var payload = new
        {
            result.DetectedPart,
            result.DamageType,
            result.RepairType,
            result.DamageLevel,
            Confidence = Math.Round(result.Confidence, 2),
            result.EstimatedCost,
            result.IsCarDamagePhoto,
            result.NeedsHumanReview,
            result.Comment,
            Items = result.Items.Select(x => new
            {
                x.DetectedPart,
                x.DamageType,
                x.RepairType,
                x.DamageLevel,
                Confidence = Math.Round(x.Confidence, 2),
                x.EstimatedCost,
                x.NeedsHumanReview,
                x.Comment
            }).ToList()
        };

        return JsonSerializer.Serialize(payload, new JsonSerializerOptions
        {
            WriteIndented = true,
            Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping
        });
    }

    private void ResetAnalysis()
    {
        ResetAnalysis(keepPhoto: false);
    }

    private void ResetAnalysis(bool keepPhoto)
    {
        errorMessage = "";
        isAnalyzing = false;
        isDemoResult = false;
        result = null;

        if (!keepPhoto)
        {
            selectedPhotoBytes = null;
            selectedPhotoContentType = "";
            selectedFileName = "";
            selectedFileSizeText = "";
            photoPreviewDataUrl = "";
        }
    }
