@page "/ai-estimate"
@page "/ai-damage"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using MyBlazorSite.Data
@using MyBlazorSite.Services
@using System.Text.Encodings.Web
@using System.Text.Json

@inject PendingAiDamageState PendingAiDamageState
@inject NavigationManager Navigation
@inject GeminiDamageAssessmentService GeminiDamageService

<div class="ai-damage-page">
    <section class="ai-damage-hero">
        <div>
            <span class="section-kicker">AI-подсказка</span>
            <h2>Оценка кузовного повреждения по фото</h2>
            <p>
                Загрузите фото повреждения. Система отправит изображение в Gemini API,
                получит структурированную подсказку и покажет результат для ручной проверки.
            </p>
        </div>

        <div class="ai-mode-badge">
            GEMINI
        </div>
    </section>

    <section class="ai-damage-grid">
        <div class="ai-glass-card">
            <div class="ai-card-title">
                <span class="ai-card-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M4 8h4l2-3h4l2 3h4v12H4z" />
                        <circle cx="12" cy="14" r="3" />
                    </svg>
                </span>

                <div>
                    <h3>Фото повреждения</h3>
                    <p>JPG, PNG или WEBP. Желательно крупный план повреждённой зоны.</p>
                </div>
            </div>

            <div class="ai-upload-zone">
                <InputFile OnChange="OnPhotoSelected"
                           accept=".jpg,.jpeg,.png,.webp"
                           class="form-control" />

                @if (!string.IsNullOrWhiteSpace(selectedFileName))
                {
                    <div class="ai-file-info">
                        <strong>@selectedFileName</strong>
                        <span>@selectedFileSizeText</span>
                    </div>
                }
                else
                {
                    <div class="ai-file-empty">
                        Фото ещё не выбрано.
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(photoPreviewDataUrl))
            {
                <div class="ai-photo-preview">
                    <img src="@photoPreviewDataUrl" alt="Фото повреждения" />
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="ai-error">
                    @errorMessage
                </div>
            }

            <div class="ai-actions">
                <button type="button"
                        class="btn btn-primary"
                        disabled="@isAnalyzing"
                        @onclick="AnalyzePhotoGemini">
                    @(isAnalyzing ? "AI анализирует..." : "Запустить Gemini-оценку")
                </button>

                <button type="button"
                        class="btn btn-outline-secondary"
                        disabled="@isAnalyzing"
                        @onclick="AnalyzePhotoDemo">
                    Демо-проверка
                </button>

                <button type="button"
                        class="btn btn-outline-secondary"
                        disabled="@isAnalyzing"
                        @onclick="ResetAnalysis">
                    Очистить
                </button>
            </div>
        </div>

        <aside class="ai-glass-card ai-result-card">
            <div class="ai-card-title">
                <span class="ai-card-icon">
                    <svg viewBox="0 0 24 24">
                        <rect x="6" y="7" width="12" height="11" rx="3" />
                        <path d="M9 7V4" />
                        <path d="M15 7V4" />
                        <circle cx="10" cy="12" r="1" />
                        <circle cx="14" cy="12" r="1" />
                        <path d="M10 16h4" />
                    </svg>
                </span>

                <div>
                    <h3>Результат AI</h3>
                    <p>Предварительная подсказка для заполнения заявки.</p>
                </div>
            </div>

            @if (isAnalyzing)
            {
                <div class="ai-loading">
                    <div class="ai-loader"></div>
                    <strong>Идёт анализ фото...</strong>
                    <span>Фото отправлено в Gemini API. Обычно это занимает несколько секунд.</span>
                </div>
            }
            else if (result is null)
            {
                <div class="ai-empty-result">
                    Загрузите фото и нажмите “Запустить Gemini-оценку”. После анализа результат можно будет перенести в новую заявку.
                </div>
            }
            else
            {
                <div class="ai-confidence">
                    <div>
                        <span>Уверенность @(isDemoResult ? "DEMO" : "Gemini")</span>
                        <strong>@((result.Confidence * 100).ToString("0"))%</strong>
                    </div>

                    <div class="ai-confidence-bar">
                        <span style="width:@((result.Confidence * 100).ToString("0"))%"></span>
                    </div>
                </div>

                @if (!result.IsCarDamagePhoto || result.NeedsHumanReview)
                {
                    <div class="ai-review-warning">
                        Результат требует ручной проверки оценщиком.
                    </div>
                }

                <div class="ai-result-grid">
                    <div class="ai-result-item">
                        <span>Основная зона</span>
                        <strong>@result.DetectedPart</strong>
                    </div>

                    <div class="ai-result-item">
                        <span>Повреждений найдено</span>
                        <strong>@result.Items.Count</strong>
                    </div>

                    <div class="ai-result-item">
                        <span>Самое серьёзное</span>
                        <strong>@result.DamageLevel</strong>
                    </div>

                    <div class="ai-result-item">
                        <span>Тип ремонта</span>
                        <strong>@result.RepairType</strong>
                    </div>
                </div>

                <div class="ai-damage-list">
                    <div class="ai-damage-list-title">
                        Видимые повреждённые зоны
                    </div>

                    @foreach (var damage in result.Items)
                    {
                        <div class="ai-damage-row">
                            <div>
                                <strong>@damage.DetectedPart</strong>
                                <span>@damage.DamageType / @damage.RepairType / @damage.DamageLevel</span>

                                @if (!string.IsNullOrWhiteSpace(damage.Comment))
                                {
                                    <small>@damage.Comment</small>
                                }
                            </div>

                            <div class="ai-damage-cost">
                                @damage.EstimatedCost.ToString("N0") ₽
                            </div>
                        </div>
                    }
                </div>

                <div class="ai-price-box">
                    <span>Предварительная сумма по найденным зонам</span>
                    <strong>@result.EstimatedCost.ToString("N0") ₽</strong>
                    <small>Это сумма локального расчёта по всем найденным AI-позициям. Финальный расчёт лучше брать из основного прайс-листа.</small>
                </div>


                @if (result.Items.Count > 0)
                {
                    <div class="ai-apply-panel">
                        <button type="button"
                                class="ai-apply-button"
                                @onclick="ApplyAiResultToRequest">
                            <span class="ai-apply-icon">
                                <svg viewBox="0 0 24 24">
                                    <path d="M5 12h14" />
                                    <path d="M13 6l6 6-6 6" />
                                </svg>
                            </span>

                            <span>
                                <strong>Применить к новой заявке</strong>
                                <small>Перенести найденные повреждения в корзину ремонта</small>
                            </span>
                        </button>

                        <div class="ai-apply-note">
                            После применения проверьте позиции, автомобиль и итоговый расчёт перед сохранением заявки.
                        </div>
                    </div>
                }

                <div class="ai-comment-box">
                    <strong>Общий комментарий AI</strong>
                    <p>@result.Comment</p>
                </div>

                @if (showTechnicalJson)
                {
                    <div class="ai-json-box">
                        <strong>Структура результата</strong>
                        <textarea readonly>@GetResultJson()</textarea>
                    </div>
                }
            }
        </aside>
    </section>

    <section class="ai-warning-card">
        <strong>Важно</strong>
        <span>
            AI-подсказка не должна автоматически утверждать стоимость ремонта.
            Результат нужно проверять вручную, а итоговую цену рассчитывать через ваш прайс-лист.
        </span>
    </section>
</div>

