@page "/products"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using MyBlazorSite.Data
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header">
            <h3 class="mb-0">Товары</h3>
        </div>

        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label">Название товара</label>
                    <input class="form-control" @bind="newName" placeholder="Например: Телефон" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Цена</label>
                    <input class="form-control" @bind="newPrice" type="number" placeholder="0" />
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="AddProduct">
                        Добавить
                    </button>
                </div>
            </div>

            @if (products.Count == 0)
            {
                <div class="alert alert-info">
                    Пока товаров нет.
                </div>
            }
            else
            {
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Название</th>
                            <th>Цена</th>
                            <th>Дата создания</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in products)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td>@product.Name</td>
                                <td>@product.Price ₽</td>
                                <td>@product.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private List<Product> products = new();
    private string newName = "";
    private decimal newPrice;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        products = await db.Products
            .OrderByDescending(p => p.Id)
            .ToListAsync();
    }

    private async Task AddProduct()
    {
        if (string.IsNullOrWhiteSpace(newName))
            return;

        await using var db = await DbFactory.CreateDbContextAsync();

        db.Products.Add(new Product
        {
            Name = newName,
            Price = newPrice
        });

        await db.SaveChangesAsync();

        newName = "";
        newPrice = 0;

        await LoadProducts();
    }
}