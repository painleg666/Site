@page "/login"
@rendermode InteractiveServer

@using MyBlazorSite.Data
@using Microsoft.AspNetCore.Components.Web
@inject AppUserState UserState
@inject NavigationManager Navigation

<div class="login-page-wrapper">
    <div class="login-card">
        <div class="login-card-header">
            <span class="login-kicker">Авторизация</span>
            <h3>Вход в систему</h3>
            <p>Введите данные администратора или оценщика.</p>
        </div>

        <div class="login-card-body">
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="login-error">
                    @errorMessage
                </div>
            }

            <div class="login-field">
                <label>Логин</label>
                <input class="login-input"
                       placeholder="Введите логин"
                       @bind="login" />
            </div>

            <div class="login-field">
                <label>Пароль</label>
                <input class="login-input"
                       type="password"
                       placeholder="Введите пароль"
                       @bind="password"
                       @onkeydown="HandleKeyDown" />
            </div>

            <button type="button"
                    class="login-submit-button"
                    @onclick="LoginAdmin">
                Войти
            </button>           
        </div>
    </div>
</div>

@code {
    private string login = "";
    private string password = "";
    private string errorMessage = "";

    private void LoginAdmin()
    {
        errorMessage = "";

        if (login == "1" && password == "1")
        {
            UserState.LoginAsAdmin();
            Navigation.NavigateTo("/");
        }
        else if (login == "2" && password == "2")
        {
            UserState.LoginAsEstimator();
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = "Неверный логин или пароль.";
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            LoginAdmin();
        }
    }
}