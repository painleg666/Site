            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.RepairType))
        {
            errorMessage = "Выберите тип ремонта.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.DamageLevel))
        {
            errorMessage = "Выберите степень повреждения.";
            return;
        }

        var pendingItems = new List<DamageCartItem>();

        foreach (var partName in selectedDamageParts.Distinct(StringComparer.OrdinalIgnoreCase))
        {
            var damagePreset = selectedDamagePreset;
            var repairType = newRequest.RepairType;
            var damageLevel = newRequest.DamageLevel;

            if (IsHeadlightPart(partName) && !IsHeadlightAllowedPreset(damagePreset))
            {
                damagePreset = "Замена детали";
                repairType = "Замена";
                damageLevel = "Сильное";
            }

            var itemCost = await CalculateSingleDamageCostAsync(
                partName,
                repairType,
                damageLevel);

            if (itemCost <= 0)
            {
                errorMessage = $"Не удалось рассчитать стоимость для детали: {partName}. Проверьте прайс-лист.";
                return;
            }

            var basePrice = await GetBasePriceForPartAsync(partName, repairType);

            pendingItems.Add(new DamageCartItem
            {
                PartName = partName,
                DamagePreset = damagePreset,
                RepairType = repairType,
                DamageLevel = damageLevel,
                BasePrice = basePrice,
                Cost = itemCost
            });
        }

        foreach (var item in pendingItems)
        {
            damageCart.RemoveAll(x =>
                string.Equals(x.PartName, item.PartName, StringComparison.OrdinalIgnoreCase));

            damageCart.Add(item);
        }

        SyncCartToRequest();
        UpdatePreviewFromCart();

        var addedCount = pendingItems.Count;

        ClearDamageSelection();

        successMessage = addedCount == 1
            ? "Повреждение добавлено в корзину. При необходимости измените параметры прямо в строке корзины."
            : $"Повреждения добавлены в корзину: {addedCount}. Теперь можно настроить тип повреждения отдельно для каждой детали.";
    }
    private async Task<decimal> GetBasePriceForPartAsync(string partName, string repairType)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var pricePartName = NormalizePartForPrice(partName);

        var priceItem = await db.RepairPriceItems
            .FirstOrDefaultAsync(x =>
                x.PartName == pricePartName &&
                x.RepairType == repairType);

        return priceItem?.BasePrice ?? 0;
    }

    private async Task<decimal> CalculateSingleDamageCostAsync(string partName, string repairType, string damageLevel)
    {
        var basePrice = await GetBasePriceForPartAsync(partName, repairType);

        if (basePrice <= 0)
            return 0;

        var damageMultiplier = GetDamageMultiplier(damageLevel);
        var brandMultiplier = GetBrandMultiplier(newRequest.CarBrand);

        return Math.Round(basePrice * damageMultiplier * brandMultiplier, 0);
    }

    private void RemoveDamageFromCart(DamageCartItem item)
