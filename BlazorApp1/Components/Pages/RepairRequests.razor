    private class PdfDamageRow
    {
        public string PartName { get; set; } = "Не указано";
        public string DamagePreset { get; set; } = "Не указано";
        public string RepairType { get; set; } = "Не указано";
        public string DamageLevel { get; set; } = "Не указано";
        public string CostText { get; set; } = "—";
    }

    private static List<PdfDamageRow> ParseDamageRows(RepairRequest request)
    {
        var result = new List<PdfDamageRow>();

        if (string.IsNullOrWhiteSpace(request.DamagedPart))
        {
            result.Add(new PdfDamageRow
            {
                PartName = "Не указано",
                DamagePreset = "Не указано",
                RepairType = SafeText(request.RepairType),
                DamageLevel = SafeText(request.DamageLevel),
                CostText = request.CalculatedCost > 0 ? $"{request.CalculatedCost:N0} ₽" : "—"
            });

            return result;
        }

        var lines = request.DamagedPart
            .Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList();

        // Новый формат: Деталь — Повреждение / Ремонт / Степень / Стоимость ₽
        foreach (var line in lines)
        {
            if (line.Contains('—') && line.Contains('/'))
            {
                var mainParts = line.Split('—', 2, StringSplitOptions.TrimEntries);
                var detail = mainParts.ElementAtOrDefault(0) ?? "Не указано";
                var tail = mainParts.ElementAtOrDefault(1) ?? "";
                var values = tail.Split('/', StringSplitOptions.TrimEntries);

                result.Add(new PdfDamageRow
                {
                    PartName = SafeText(detail),
                    DamagePreset = SafeText(values.ElementAtOrDefault(0)),
                    RepairType = SafeText(values.ElementAtOrDefault(1)),
                    DamageLevel = SafeText(values.ElementAtOrDefault(2)),
                    CostText = SafeText(values.ElementAtOrDefault(3))
                });
            }
        }

        if (result.Count > 0)
            return result;

        // Старый формат: Деталь (Повреждение), Деталь (Повреждение)
        var oldParts = request.DamagedPart
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList();

        if (oldParts.Count == 0)
        {
            oldParts.Add(request.DamagedPart);
        }

        var fallbackCost = oldParts.Count == 1 && request.CalculatedCost > 0
            ? $"{request.CalculatedCost:N0} ₽"
            : "—";

        foreach (var part in oldParts)
        {
            var partName = part;
            var damagePreset = "Не указано";

            var openIndex = part.IndexOf('(');
            var closeIndex = part.LastIndexOf(')');

            if (openIndex > 0 && closeIndex > openIndex)
            {
                partName = part[..openIndex].Trim();
                damagePreset = part[(openIndex + 1)..closeIndex].Trim();
            }

            result.Add(new PdfDamageRow
            {
                PartName = SafeText(partName),
                DamagePreset = SafeText(damagePreset),
                RepairType = SafeText(request.RepairType),
                DamageLevel = SafeText(request.DamageLevel),
                CostText = fallbackCost
            });
        }

        return result;
    }

    private static void BuildDamageCard(IContainer container, RepairRequest request)
    {
        var damageRows = ParseDamageRows(request);

        container
            .Border(1)
            .BorderColor(Colors.Grey.Lighten2)
            .Background(Colors.White)
            .Padding(12)
            .Column(column =>
            {
                column.Spacing(10);

                column.Item()
                    .Row(row =>
                    {
                        row.RelativeItem()
                            .Text("Повреждения и ремонт")
                            .FontSize(12)
                            .Bold()
                            .FontColor(Colors.Blue.Darken4);

                        row.ConstantItem(130)
                            .AlignRight()
                            .Text($"Позиций: {damageRows.Count}")
                            .FontSize(9)
                            .FontColor(Colors.Grey.Medium);
                    });

                column.Item()
                    .Table(table =>
                    {
                        table.ColumnsDefinition(columns =>
                        {
                            columns.RelativeColumn(1.65f);
                            columns.RelativeColumn(1.15f);
                            columns.RelativeColumn(1.05f);
                            columns.RelativeColumn(1.05f);
                            columns.RelativeColumn(1.05f);
                        });

                        table.Header(header =>
                        {
                            header.Cell().Element(TableHeaderCell).Text("Деталь");
                            header.Cell().Element(TableHeaderCell).Text("Повреждение");
                            header.Cell().Element(TableHeaderCell).Text("Ремонт");
                            header.Cell().Element(TableHeaderCell).Text("Степень");
                            header.Cell().Element(TableHeaderCell).AlignRight().Text("Стоимость");
                        });

                        foreach (var row in damageRows)
                        {
                            table.Cell().Element(TableBodyCell).Text(row.PartName);
                            table.Cell().Element(TableBodyCell).Text(row.DamagePreset);
                            table.Cell().Element(TableBodyCell).Text(row.RepairType);
                            table.Cell().Element(TableBodyCell).Text(row.DamageLevel);
                            table.Cell().Element(TableBodyCell).AlignRight().Text(row.CostText);
                        }
                    });
            });
    }

    private static void BuildPhotoCard(IContainer container, byte[]? photoBytes)
    {
        container
            .Border(1)
            .BorderColor(Colors.Grey.Lighten2)
            .Background(Colors.White)
            .Padding(12)
            .Column(column =>
            {
                column.Spacing(10);

                column.Item()
                    .Text("Фото повреждения")
                    .FontSize(12)
                    .Bold()
                    .FontColor(Colors.Blue.Darken4);

                if (photoBytes is not null)
                {
                    column.Item()
                        .Height(190)
                        .AlignCenter()
                        .Image(photoBytes)
                        .FitArea();
                }
                else
                {
                    column.Item()
                        .Height(190)
                        .Border(1)
                        .BorderColor(Colors.Grey.Lighten2)
                        .Background(Colors.Grey.Lighten5)
                        .AlignCenter()
                        .AlignMiddle()
                        .Text("Фото к заявке не загружено")
                        .FontSize(10)
                        .FontColor(Colors.Grey.Medium);
                }
            });
    }

