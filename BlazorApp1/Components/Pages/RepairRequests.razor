                                              @onclick='() => SelectDamagePart("Правая дверь")' />
                                        <svg:text x="363" y="405" class="svg-label-v2 small">Правая дверь</svg:text>
                                    }
                                    else
                                    {
                                        <path d="M128 292 Q154 276 186 292 L184 396 Q154 410 128 390 Z"
                                              class='@GetSvgZoneClass("Передняя левая дверь", "svg-zone-v2 zone-door-v2")'
                                              @onclick='() => SelectDamagePart("Передняя левая дверь")' />
                                        <svg:text x="157" y="350" class="svg-label-v2 small">Перед. дверь</svg:text>

                                        <path d="M128 402 Q154 386 184 402 L184 500 Q154 522 128 490 Z"
                                              class='@GetSvgZoneClass("Задняя левая дверь", "svg-zone-v2 zone-door-v2")'
                                              @onclick='() => SelectDamagePart("Задняя левая дверь")' />
                                        <svg:text x="157" y="458" class="svg-label-v2 small">Зад. дверь</svg:text>

                                        <path d="M392 292 Q366 276 334 292 L336 396 Q366 410 392 390 Z"
                                              class='@GetSvgZoneClass("Передняя правая дверь", "svg-zone-v2 zone-door-v2")'
                                              @onclick='() => SelectDamagePart("Передняя правая дверь")' />
                                        <svg:text x="363" y="350" class="svg-label-v2 small">Перед. дверь</svg:text>

                                        <path d="M392 402 Q366 386 336 402 L336 500 Q366 522 392 490 Z"
                                              class='@GetSvgZoneClass("Задняя правая дверь", "svg-zone-v2 zone-door-v2")'
                                              @onclick='() => SelectDamagePart("Задняя правая дверь")' />
                                        <svg:text x="363" y="458" class="svg-label-v2 small">Зад. дверь</svg:text>
                                    }

                                    <path d="M132 506 Q158 486 190 504 L184 610 Q154 636 128 600 Z"
                                          class='@GetSvgZoneClass("Заднее левое крыло", "svg-zone-v2 zone-rear-fender-v2")'
                                          @onclick='() => SelectDamagePart("Заднее левое крыло")' />
                                    <svg:text x="158" y="560" class="svg-label-v2 small">Зад. лев. крыло</svg:text>

                                    <path d="M388 506 Q362 486 330 504 L336 610 Q366 636 392 600 Z"
                                          class='@GetSvgZoneClass("Заднее правое крыло", "svg-zone-v2 zone-rear-fender-v2")'
                                          @onclick='() => SelectDamagePart("Заднее правое крыло")' />
                                    <svg:text x="362" y="560" class="svg-label-v2 small">Зад. прав. крыло</svg:text>

                                    <path d="M96 304 Q112 304 118 326 L118 542 Q112 566 96 566 Q82 548 82 436 Q82 326 96 304 Z"
                                          class='@GetSvgZoneClass("Порог", "svg-zone-v2 zone-sill-v2")'
                                          @onclick='() => SelectDamagePart("Порог")' />

                                    <path d="M424 304 Q408 304 402 326 L402 542 Q408 566 424 566 Q438 548 438 436 Q438 326 424 304 Z"
                                          class='@GetSvgZoneClass("Порог", "svg-zone-v2 zone-sill-v2")'
                                          @onclick='() => SelectDamagePart("Порог")' />

                                    <path d="@GetRearDeckPathV2()"
                                          class='@GetSvgZoneClass("Крышка багажника", "svg-zone-v2 zone-trunk-v2")'
                                          @onclick='() => SelectDamagePart("Крышка багажника")' />
                                    <svg:text x="260" y="592" class="svg-label-v2">@GetRearDeckLabel()</svg:text>

                                    <path d="M156 622 Q176 610 196 622 Q190 642 164 646 Q150 638 156 622 Z"
                                          class='@GetSvgZoneClass("Задняя левая фара", "svg-zone-v2 zone-light-rear-v2")'
                                          @onclick='() => SelectDamagePart("Задняя левая фара")' />

                                    <path d="M364 622 Q344 610 324 622 Q330 642 356 646 Q370 638 364 622 Z"
                                          class='@GetSvgZoneClass("Задняя правая фара", "svg-zone-v2 zone-light-rear-v2")'
                                          @onclick='() => SelectDamagePart("Задняя правая фара")' />

                                    <path d="M174 650 Q260 680 346 650 Q356 668 342 690 L178 690 Q164 668 174 650 Z"
                                          class='@GetSvgZoneClass("Задний бампер", "svg-zone-v2 zone-rear-v2")'
                                          @onclick='() => SelectDamagePart("Задний бампер")' />
                                    <svg:text x="260" y="674" class="svg-label-v2">Задний бампер</svg:text>

                                    <path d="M90 186 Q52 230 74 284" class="wheel-arch-v2" />
                                    <path d="M430 186 Q468 230 446 284" class="wheel-arch-v2" />
                                    <path d="M94 490 Q56 536 82 592" class="wheel-arch-v2" />
                                    <path d="M426 490 Q464 536 438 592" class="wheel-arch-v2" />
                                </svg>
                            </div>

                            <div class="damage-map-legend">
                                <span><i class="legend-dot selected"></i> выбранная зона</span>
                                <span><i class="legend-dot available"></i> доступная зона</span>
                                <span><i class="legend-dot hover"></i> наведение</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="repair-divider"></div>

                <div class="repair-card-title">
                    <span class="section-svg-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M4 8h4l2-3h4l2 3h4v12H4z" />
                            <circle cx="12" cy="14" r="3" />
                        </svg>
                    </span>
                    <h3>Фото повреждения</h3>
                </div>

                <div class="upload-panel">
                    <div class="upload-icon">☁️</div>

                    <div class="upload-content">
                        <strong>Загрузите фото автомобиля или повреждения</strong>
                        <span>JPG, PNG, WEBP. Файл будет сохранён в заявку.</span>

                        <input id="repairPhotoInput"
                               class="form-control"
                               type="file"
                               accept=".jpg,.jpeg,.png,.webp"
                               onchange="uploadRepairPhoto(this)" />

                        <input id="repairPhotoPath" type="hidden" />

                        <small id="repairPhotoMessage" class="text-muted"></small>
                    </div>
                </div>
            </div>

            <aside class="repair-summary-card">
                <div class="summary-title">
                    <span class="summary-svg-icon">
                        <svg viewBox="0 0 24 24">
                            <rect x="3" y="6" width="18" height="12" rx="2"></rect>
                            <path d="M3 10h18"></path>
                            <path d="M7 14h4"></path>
                        </svg>
                    </span>
                    <div>
                        <h3>Предварительный расчёт</h3>
                        <p>Стоимость по выбранным параметрам</p>
                    </div>
                </div>

                <div class="summary-price">
                    @previewCost.ToString("N0") ₽
                </div>

                @if (previewCost > 0)
                {
                    <div class="summary-breakdown">
                        <div>
                            <span>Базовая цена</span>
                            <strong>@previewBasePrice.ToString("N0") ₽</strong>
                        </div>

                        <div>
                            <span>Коэффициент повреждения</span>
                            <strong>x@(previewDamageMultiplier.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))</strong>
                        </div>

                        <div>
                            <span>Коэффициент марки @newRequest.CarBrand</span>
                            <strong>x@(previewBrandMultiplier.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))</strong>
                        </div>

                        <div class="summary-total-row">
                            <span>Итого</span>
                            <strong>@previewCost.ToString("N0") ₽</strong>
                        </div>
                    </div>
                }
                else
                {
                    <div class="summary-empty">
                        Выберите деталь, тип ремонта, степень повреждения и автомобиль.
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="summary-error">
                        @errorMessage
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="summary-success">
                        @successMessage
                    </div>
                }

                <div class="summary-actions">
                    <button class="btn btn-outline-secondary w-100" @onclick="UpdatePreviewCost">
                        Рассчитать стоимость
                    </button>

                    <button class="btn btn-primary w-100" @onclick="AddRequest">
                        Рассчитать и сохранить заявку
                    </button>
                </div>

                <div class="summary-hint">
                    <strong>Формула расчёта</strong>
                    <span>Сумма базовых цен × повреждение × марка автомобиля</span>
                </div>
            </aside>
        </div>
    </section>

    <section id="requests-list" class="requests-section">
        <div class="requests-header">
            <div>
                <span class="section-kicker">Журнал обращений</span>
                <h2>@(UserState.CanSeeAllRequests ? "Список заявок" : "Мои заявки")</h2>
            </div>

            @if (UserState.CanSeeAllRequests)
            {
                <div class="requests-filters">
                    <input class="form-control"
                           placeholder="Поиск по имени, телефону, марке или модели"
                           @bind="searchText" />

                    <select class="form-select" @bind="statusFilter">
                        <option value="">Все статусы</option>
                        <option>Новая</option>
                        <option>В обработке</option>
                        <option>Оценена</option>
                        <option>Завершена</option>
                    </select>

                    <button class="btn btn-outline-primary" @onclick="LoadRequests">
                        Применить
                    </button>

                    <button class="btn btn-outline-secondary" @onclick="ResetFilters">
                        Сбросить
                    </button>
                </div>
            }

        </div>

        @if (requests.Count == 0)
        {
            <div class="alert alert-info">Заявок пока нет.</div>
        }
        else
        {
            <div class="table-responsive-mobile">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Код заявки</th>
                            <th>Клиент</th>
                            <th>Авто</th>
                            <th>Повреждение</th>
                            <th>Фото</th>
                            <th>Стоимость</th>
                            <th>Статус</th>
                            <th>Дата</th>
                            <th>Действия</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in requests)
                        {
                            <tr>
                                <td>
                                    <strong>@GetRequestPublicCode(item)</strong><br />
                                    <small class="text-muted">ID: @item.Id</small>
                                </td>

                                <td>
                                    <strong>@item.ClientName</strong><br />
                                    <small class="text-muted">@item.Phone</small>
                                </td>

                                <td>
                                    <strong>@item.CarBrand @item.CarModel</strong>
                                    <br />
                                    <small class="text-muted">
                                        @item.CarGeneration, @item.CarYear г.
                                    </small>
                                </td>

                                <td>
                                    @item.DamagedPart<br />
                                    <small class="text-muted">
                                        @item.RepairType, @item.DamageLevel
                                    </small>
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.PhotoPath))
                                    {
                                        <img src="@item.PhotoPath"
                                             alt="Фото повреждения"
                                             style="width: 90px; height: 70px; object-fit: cover; border-radius: 10px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Нет фото</span>
                                    }
                                </td>

                                <td>
                                    <strong>@item.CalculatedCost.ToString("N0") ₽</strong>
                                </td>

                                <td>
                                    <span class="badge @GetStatusBadgeClass(item.Status)">
                                        @item.Status
                                    </span>
                                </td>

                                <td>
                                    @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </td>

                                <td>
                                    <div class="request-table-actions">
                                        <button type="button"
                                                class="request-table-action request-table-action-primary"
                                                @onclick="() => OpenRequestDetails(item)">
                                            Открыть
                                        </button>

                                        <button type="button"
                                                class="request-table-action request-table-action-secondary"
                                                @onclick="() => DownloadPdf(item.Id)">
                                            PDF
                                        </button>

                                        @if (UserState.CanSeeAllRequests)
                                        {
                                            <button type="button"
                                                    class="request-table-action request-table-action-danger"
                                                    @onclick="() => DeleteRequest(item.Id)">
                                                Удалить
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
    @if (selectedRequest is not null)
    {
        <div class="request-details-backdrop" @onclick="CloseRequestDetails">
            <div class="request-details-modal" @onclick:stopPropagation="true">
                <div class="request-details-header">
                    <div>
                        <span class="request-details-kicker">Заявка @GetRequestPublicCode(selectedRequest)</span>
                        <h3>@selectedRequest.ClientName</h3>
                    </div>

                    <button type="button"
                            class="request-details-close"
                            @onclick="CloseRequestDetails">
                        ×
                    </button>
                </div>

                <div class="request-details-body">
                    <div class="request-details-main">
                        <div class="request-details-card">
                            <h4>Клиент и автомобиль</h4>

                            <div class="request-info-grid">
                                <div class="request-info-item">
                                    <span>Клиент</span>
                                    <strong>@selectedRequest.ClientName</strong>
                                </div>

                                <div class="request-info-item">
                                    <span>Телефон</span>
                                    <strong>@selectedRequest.Phone</strong>
                                </div>

                                <div class="request-info-item">
                                    <span>Автомобиль</span>
                                    <strong>@selectedRequest.CarBrand @selectedRequest.CarModel</strong>
                                </div>

                                <div class="request-info-item">
                                    <span>Поколение / год</span>
                                    <strong>@selectedRequest.CarGeneration, @selectedRequest.CarYear г.</strong>
                                </div>
                            </div>
                        </div>

                        <div class="request-details-card">
                            <h4>Повреждения</h4>

                            <div class="request-damage-text">
                                @selectedRequest.DamagedPart
                            </div>

                            <div class="request-info-grid" style="margin-top: 14px;">
                                <div class="request-info-item">
                                    <span>Тип ремонта</span>
                                    <strong>@selectedRequest.RepairType</strong>
                                </div>

                                <div class="request-info-item">
                                    <span>Степень повреждения</span>
                                    <strong>@selectedRequest.DamageLevel</strong>
                                </div>
                            </div>
                        </div>

                        <div class="request-details-card">
                            <h4>Фото повреждения</h4>

                            <div class="request-photo-box">
                                @if (!string.IsNullOrWhiteSpace(selectedRequest.PhotoPath))
                                {
                                    <img src="@selectedRequest.PhotoPath" alt="Фото повреждения" />
                                }
                                else
                                {
                                    <div class="request-photo-empty">
                                        Фото к заявке не загружено.
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(selectedRequest.PhotoPath))
                            {
                                <div class="request-photo-actions">
                                    <button type="button"
                                            class="photo-preview-button"
                                            @onclick="() => OpenPhotoViewer(selectedRequest.PhotoPath)">
                                        🔍 Просмотр фото
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    <aside class="request-details-side">
                        <div class="request-details-card">
                            <h4>Стоимость</h4>

                            <div class="request-price-large">
                                @selectedRequest.CalculatedCost.ToString("N0") ₽
                            </div>
                        </div>

                        <div class="request-details-card">
                            <h4>Статус заявки</h4>

                            <div style="margin-bottom: 14px;">
                                <span class="badge @GetStatusBadgeClass(selectedRequest.Status)">
                                    @selectedRequest.Status
                                </span>
                            </div>

                            <div class="request-status-timeline">
                                @foreach (var step in requestStatusSteps)
                                {
                                    <div class="@GetStatusStepClass(selectedRequest.Status, step.Status)">
                                        <div class="status-step-title">@step.Title</div>
                                        <div class="status-step-caption">@step.Caption</div>
                                    </div>
                                }
                            </div>

                            <div class="client-status-message">
                                <strong>@GetClientStatusTitle(selectedRequest.Status)</strong>
                                <div>@GetClientStatusDescription(selectedRequest.Status)</div>
                            </div>

                            @if (UserState.CanChangeRequestStatus)
                            {
                                <div class="request-status-actions" style="margin-top: 16px;">
                                    <button type="button"
                                            class="btn btn-outline-primary"
                                            @onclick='async () => await ChangeSelectedRequestStatus("Новая")'>
                                        Новая
                                    </button>

                                    <button type="button"
                                            class="btn btn-outline-warning"
                                            @onclick='async () => await ChangeSelectedRequestStatus("В обработке")'>
                                        В обработке
                                    </button>

                                    <button type="button"
                                            class="btn btn-outline-success"
                                            @onclick='async () => await ChangeSelectedRequestStatus("Оценена")'>
                                        Оценена
                                    </button>

                                    <button type="button"
                                            class="btn btn-outline-secondary"
                                            @onclick='async () => await ChangeSelectedRequestStatus("Завершена")'>
                                        Завершена
                                    </button>
                                </div>
                            }
                        </div>

                        <div class="request-details-card">
                            <h4>Служебная информация</h4>

                            <div class="request-info-grid" style="grid-template-columns: 1fr;">
                                <div class="request-info-item">
                                    <span>Дата создания</span>
                                    <strong>@selectedRequest.CreatedAt.ToString("dd.MM.yyyy HH:mm")</strong>
                                </div>

                                <div class="request-info-item">
                                    <span>ID заявки</span>
                                    <strong>#@selectedRequest.Id</strong>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>

                <div class="request-details-footer">
                    <button type="button"
                            class="btn btn-outline-dark"
                            @onclick="() => DownloadPdf(selectedRequest.Id)">
                        Скачать PDF
                    </button>

                    <button type="button"
                            class="btn btn-primary"
                            @onclick="CloseRequestDetails">
                        Закрыть
                    </button>
                </div>
            </div>
        </div>
    }
    
    @if (!string.IsNullOrWhiteSpace(openedPhotoPath))
    {
        <div class="photo-viewer-backdrop" @onclick="ClosePhotoViewer">
            <div class="photo-viewer-modal" @onclick:stopPropagation="true">
                <div class="photo-viewer-header">
                    <strong>Фото повреждения</strong>

                    <button type="button"
                            class="photo-viewer-close"
                            @onclick="ClosePhotoViewer">
                        ×
                    </button>
