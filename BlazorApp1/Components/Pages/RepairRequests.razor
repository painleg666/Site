    private async Task OnCartDamagePresetChanged(DamageCartItem item, ChangeEventArgs e)
    {
        var preset = e.Value?.ToString() ?? "";

        if (string.IsNullOrWhiteSpace(preset))
            return;

        if (IsHeadlightPart(item.PartName) && !IsHeadlightAllowedPreset(preset))
            return;

        item.DamagePreset = preset;

        var defaults = GetPresetDefaults(preset);
        item.RepairType = defaults.RepairType;
        item.DamageLevel = defaults.DamageLevel;

        await RecalculateCartItemAsync(item);
    }

