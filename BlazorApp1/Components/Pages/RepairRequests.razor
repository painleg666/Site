@page "/repair-requests"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MyBlazorSite.Data
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure
@using System.IO
@using System.Security.Cryptography

@inject DashboardStatsNotifier StatsNotifier
@inject IWebHostEnvironment Env
@inject AppDbContext Db
@inject AppUserState UserState
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IDbContextFactory<AppDbContext> DbFactory
@inject PendingAiDamageState PendingAiDamageState
<style>
    /* ===== DAMAGE MAP: SELECTED PARTS ===== */

    .part-dot.rear-fender {
        background: #38bdf8;
    }

    .part-dot.door-front {
        background: #22c55e;
    }

    .part-dot.door-rear {
        background: #10b981;
    }

    .part-dot.light-front {
        background: #facc15;
    }

    .part-dot.light-rear {
        background: #fb7185;
    }

    .part-check {
        margin-left: auto;
        width: 22px;
        height: 22px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: #1e8bff;
        color: #ffffff;
        font-size: 13px;
    }

    .selected-damage-info-list {
        min-width: 260px;
    }

    .selected-parts-list {
        margin-top: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .selected-part-pill {
        min-height: 30px;
        padding: 0 10px;
        border-radius: 999px;
        border: 1px solid rgba(50, 213, 131, 0.32);
        background: rgba(50, 213, 131, 0.12);
        color: #d8ffe9;
        font-size: 13px;
        font-weight: 700;
    }

        .selected-part-pill span {
            margin-left: 6px;
            color: #ffffff;
        }

    /* ===== REAL VEHICLE UNDERLAY MAP ===== */

    .vehicle-map-card-v2 {
        overflow: hidden;
    }

    .real-blueprint-v2 {
        position: relative;
        min-height: 700px;
        padding: 14px;
        display: grid;
        place-items: center;
        border-radius: 20px;
        background: radial-gradient(circle at center, rgba(59, 130, 246, 0.10), transparent 45%), linear-gradient(rgba(120, 160, 255, 0.055) 1px, transparent 1px), linear-gradient(90deg, rgba(120, 160, 255, 0.055) 1px, transparent 1px), rgba(3, 12, 27, 0.82);
        background-size: auto, 34px 34px, 34px 34px, auto;
        border: 1px solid rgba(120, 160, 255, 0.14);
        overflow: hidden;
    }

        .real-blueprint-v2::after {
            content: "";
            position: absolute;
            inset: 6%;
            z-index: 1;
            pointer-events: none;
            background: radial-gradient(circle at center, transparent 42%, rgba(3, 12, 27, 0.28) 74%);
        }

    .blueprint-body-underlay {
        position: absolute;
        inset: 0;
        background-repeat: no-repeat;
        background-position: center center;
        background-size: auto 100%;
        opacity: 0.50;
        pointer-events: none;
        z-index: 1;
        filter: drop-shadow(0 0 28px rgba(80, 160, 255, 0.34)) saturate(1.18) contrast(1.06);
    }

        .blueprint-body-underlay.underlay-sedan {
            background-image: url('/images/body-sedan.png');
            background-size: auto 100%;
            background-position: center 50%;
        }

        .blueprint-body-underlay.underlay-hatchback {
            background-image: url('/images/body-hatchback.png');
            background-size: auto 98%;
            background-position: center 50%;
        }

        .blueprint-body-underlay.underlay-suv {
            background-image: url('/images/body-suv.png');
            background-size: auto 102%;
            background-position: center 49%;
        }

        .blueprint-body-underlay.underlay-wagon {
            background-image: url('/images/body-wagon.png');
            background-size: auto 102%;
            background-position: center 49%;
        }

        .blueprint-body-underlay.underlay-coupe {
            background-image: url('/images/body-coupe.png');
            background-size: auto 101%;
            background-position: center 50%;
        }

    .vehicle-svg-v2 {
        position: relative;
        z-index: 2;
        width: 100%;
        height: auto;
        pointer-events: auto;
        filter: drop-shadow(0 0 24px rgba(13, 110, 253, 0.18));
    }

        .vehicle-svg-v2.svg-sedan {
            max-width: 485px;
            transform: translateY(0px) scale(1.08);
            transform-origin: center;
        }

        .vehicle-svg-v2.svg-hatchback {
            max-width: 475px;
            transform: translateY(2px) scale(1.06);
            transform-origin: center;
        }

        .vehicle-svg-v2.svg-suv {
            max-width: 500px;
            transform: translateY(-2px) scale(1.10);
            transform-origin: center;
        }

        .vehicle-svg-v2.svg-wagon {
            max-width: 495px;
            transform: translateY(-2px) scale(1.09);
            transform-origin: center;
        }

        .vehicle-svg-v2.svg-coupe {
            max-width: 490px;
            transform: translateY(2px) scale(1.07);
            transform-origin: center;
        }

            .vehicle-svg-v2.svg-coupe .svg-label-v2 {
                font-size: 12px;
            }

                .vehicle-svg-v2.svg-coupe .svg-label-v2.small {
                    font-size: 10px;
                }

    /* SVG base parts: almost transparent, because PNG underlay is the main visual */

    .vehicle-shadow-v2 {
        fill: rgba(13, 110, 253, 0.02);
    }

    .vehicle-shell-v2 {
        fill: rgba(30, 64, 120, 0.008) !important;
        stroke: rgba(219, 234, 254, 0.18) !important;
        stroke-width: 1.4 !important;
    }

    .vehicle-cabin-v2 {
        fill: rgba(15, 23, 42, 0.01) !important;
        stroke: rgba(191, 219, 254, 0.06) !important;
        stroke-width: 1.2;
    }

    .vehicle-glass-v2,
    .vehicle-side-glass-v2 {
        fill: rgba(147, 197, 253, 0.01) !important;
        stroke: rgba(191, 219, 254, 0.06) !important;
        stroke-width: 1.1;
    }

    .vehicle-axis-v2 {
        stroke: rgba(219, 234, 254, 0.14);
        stroke-width: 1.2;
        stroke-dasharray: 7 9;
    }

    .wheel-arch-v2 {
        fill: none;
        stroke: rgba(219, 234, 254, 0.20);
        stroke-width: 4;
        stroke-linecap: round;
    }

    /* SVG clickable zones */

    .svg-zone-v2 {
        cursor: pointer;
        transition: 0.18s ease;
        stroke-width: 1.25;
        opacity: 0.66;
        filter: saturate(1.05);
    }

        .svg-zone-v2:hover {
            opacity: 0.93;
            filter: brightness(1.24) saturate(1.25);
            transform-box: fill-box;
            transform-origin: center;
            transform: scale(1.02);
        }

        .svg-zone-v2.active {
            opacity: 1;
            stroke: #32d583 !important;
            stroke-width: 2.4;
            filter: drop-shadow(0 0 12px rgba(50, 213, 131, 0.42));
        }

    .zone-front-v2 {
        fill: rgba(239, 68, 68, 0.22);
        stroke: rgba(239, 68, 68, 0.58);
    }

    .zone-light-front-v2 {
        fill: rgba(250, 204, 21, 0.26);
        stroke: rgba(250, 204, 21, 0.62);
    }

    .zone-light-rear-v2 {
        fill: rgba(251, 113, 133, 0.24);
        stroke: rgba(251, 113, 133, 0.62);
    }

    .zone-hood-v2 {
        fill: rgba(139, 92, 246, 0.18);
        stroke: rgba(139, 92, 246, 0.55);
    }

    .zone-fender-v2 {
        fill: rgba(30, 139, 255, 0.16);
        stroke: rgba(30, 139, 255, 0.55);
    }

    .zone-rear-fender-v2 {
        fill: rgba(56, 189, 248, 0.18);
        stroke: rgba(56, 189, 248, 0.58);
    }

    .zone-door-v2 {
        fill: rgba(34, 197, 94, 0.16);
        stroke: rgba(34, 197, 94, 0.52);
    }

    .zone-sill-v2 {
        fill: rgba(20, 184, 166, 0.18);
        stroke: rgba(20, 184, 166, 0.54);
    }

    .zone-trunk-v2 {
        fill: rgba(249, 115, 22, 0.18);
        stroke: rgba(249, 115, 22, 0.56);
    }

    .zone-rear-v2 {
        fill: rgba(251, 113, 133, 0.18);
        stroke: rgba(251, 113, 133, 0.56);
    }

    .svg-label-v2 {
        fill: #f8fbff;
        font-size: 13px;
        font-weight: 850;
        text-anchor: middle;
        pointer-events: none;
        paint-order: stroke;
        stroke: rgba(3, 12, 27, 0.95);
        stroke-width: 4px;
        stroke-linejoin: round;
    }

        .svg-label-v2.small {
            font-size: 12px;
        }

    @@media (max-width: 1100px) {
        .real-blueprint-v2 {
            min-height: 580px;
        }

        .vehicle-svg-v2.svg-sedan,
        .vehicle-svg-v2.svg-hatchback,
        .vehicle-svg-v2.svg-suv,
        .vehicle-svg-v2.svg-wagon,
        .vehicle-svg-v2.svg-coupe {
            max-width: 410px;
            transform: translateY(0px) scale(0.95);
        }

        .blueprint-body-underlay.underlay-sedan,
        .blueprint-body-underlay.underlay-hatchback,
        .blueprint-body-underlay.underlay-suv,
        .blueprint-body-underlay.underlay-wagon,
        .blueprint-body-underlay.underlay-coupe {
            background-size: auto 92%;
            background-position: center 50%;
        }
    }

    .damage-chip.disabled,
    .damage-chip:disabled {
        opacity: 0.35;
        cursor: not-allowed;
        filter: grayscale(1);
        pointer-events: none;
    }

    .damage-cart-actions {
        margin-top: 16px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .damage-cart-panel {
        margin-top: 18px;
        padding: 18px;
        border-radius: 18px;
        background: rgba(7, 19, 38, 0.48);
        border: 1px solid rgba(120, 160, 255, 0.14);
    }

    .damage-cart-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 14px;
    }

        .damage-cart-header h3 {
            margin: 0;
            color: #ffffff;
            font-size: 19px;
            font-weight: 850;
        }

        .damage-cart-header p {
            margin: 5px 0 0;
            color: #9fb3d9;
            font-size: 13px;
        }

        .damage-cart-header strong {
            min-width: 34px;
            height: 34px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            background: rgba(13, 110, 253, 0.22);
            color: #ffffff;
        }

    .damage-cart-empty {
        padding: 14px;
        border-radius: 14px;
        color: #9fb3d9;
        background: rgba(255, 255, 255, 0.035);
        border: 1px dashed rgba(120, 160, 255, 0.18);
    }

    .damage-cart-list {
        display: grid;
        gap: 10px;
    }

    .damage-cart-item {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto 42px;
        gap: 12px;
        align-items: center;
        padding: 12px 14px;
        border-radius: 14px;
        background: rgba(24, 40, 68, 0.72);
        border: 1px solid rgba(120, 160, 255, 0.12);
    }

        .damage-cart-item strong {
            display: block;
            color: #ffffff;
        }

        .damage-cart-item span {
            display: block;
            margin-top: 3px;
            color: #9fb3d9;
            font-size: 13px;
        }

    .damage-cart-price {
        color: #32d583;
        font-weight: 900;
        white-space: nowrap;
    }

    .damage-cart-remove {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        border: 1px solid rgba(255, 77, 109, 0.35);
        background: rgba(255, 77, 109, 0.12);
        color: #ffb8c5;
    }
    /* ===== REQUEST DETAILS MODAL: COMPACT FIX ===== */

    .request-details-backdrop {
        position: fixed;
        inset: 0;
        z-index: 2500;
        background: rgba(3, 12, 27, 0.78);
        backdrop-filter: blur(8px);
        display: grid;
        place-items: center;
        padding: 18px;
        overflow: hidden;
    }

    .request-details-modal {
        width: min(1080px, calc(100vw - 36px));
        max-height: calc(100vh - 36px);
        overflow: hidden;
        border-radius: 24px;
        background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.20), transparent 38%), rgba(7, 19, 38, 0.98);
        border: 1px solid rgba(120, 160, 255, 0.22);
        box-shadow: 0 32px 90px rgba(0, 0, 0, 0.55);
        display: flex;
        flex-direction: column;
    }

    .request-details-header {
        flex: 0 0 auto;
        padding: 18px 22px;
        border-bottom: 1px solid rgba(120, 160, 255, 0.14);
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
    }

        .request-details-header h3 {
            margin: 4px 0 0;
            color: #ffffff;
            font-size: 28px;
            line-height: 1.1;
            font-weight: 900;
        }

    .request-details-kicker {
        color: #9fb3d9;
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .request-details-close {
        width: 40px;
        height: 40px;
        flex: 0 0 auto;
        border-radius: 13px;
        border: 1px solid rgba(120, 160, 255, 0.18);
        background: rgba(255, 255, 255, 0.04);
        color: #ffffff;
        font-size: 26px;
        line-height: 1;
    }

    .request-details-body {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 20px 22px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 18px;
    }

    .request-details-main,
    .request-details-side {
        min-width: 0;
        display: grid;
        gap: 14px;
        align-content: start;
    }

    .request-details-card {
        min-width: 0;
        padding: 16px;
        border-radius: 18px;
        background: rgba(24, 40, 68, 0.72);
        border: 1px solid rgba(120, 160, 255, 0.14);
    }

        .request-details-card h4 {
            margin: 0 0 12px;
            color: #ffffff;
            font-size: 18px;
            line-height: 1.2;
            font-weight: 850;
        }

    .request-info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .request-info-item {
        min-width: 0;
        padding: 12px 13px;
        border-radius: 14px;
        background: rgba(7, 19, 38, 0.48);
        border: 1px solid rgba(120, 160, 255, 0.10);
    }

        .request-info-item span {
            display: block;
            color: #9fb3d9;
            font-size: 12px;
            margin-bottom: 5px;
        }

        .request-info-item strong {
            display: block;
            color: #ffffff;
            font-weight: 850;
            overflow-wrap: anywhere;
        }

    .request-damage-text {
        color: #d8e8ff;
        line-height: 1.5;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
    }

    .request-photo-box {
        height: 230px;
        border-radius: 16px;
        overflow: hidden;
        background: rgba(7, 19, 38, 0.62);
        border: 1px solid rgba(120, 160, 255, 0.14);
        display: grid;
        place-items: center;
        position: relative;
    }

        .request-photo-box img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            background: rgba(3, 12, 27, 0.88);
        }

    .request-photo-actions {
        margin-top: 12px;
        display: flex;
        justify-content: flex-end;
    }

    .photo-preview-button {
        min-height: 38px;
        padding: 0 14px;
        border-radius: 12px;
        border: 1px solid rgba(120, 160, 255, 0.24);
        background: rgba(13, 110, 253, 0.14);
        color: #dbeafe;
        font-weight: 800;
    }

        .photo-preview-button:hover {
            background: rgba(13, 110, 253, 0.24);
            border-color: rgba(80, 160, 255, 0.72);
        }

    .request-photo-empty {
        color: #9fb3d9;
        padding: 24px;
        text-align: center;
    }

    .request-price-large {
        color: #32d583;
        font-size: 36px;
        line-height: 1;
        font-weight: 950;
        letter-spacing: -0.04em;
        white-space: nowrap;
    }

    .request-status-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

        .request-status-actions button {
            min-height: 40px;
            border-radius: 12px;
            font-weight: 850;
            font-size: 13px;
        }

    .request-details-footer {
        flex: 0 0 auto;
        padding: 14px 22px;
        border-top: 1px solid rgba(120, 160, 255, 0.14);
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    /* ===== REQUEST STATUS TIMELINE: VERTICAL FIX ===== */

    .request-status-timeline {
        display: grid;
        grid-template-columns: 1fr;
        gap: 9px;
        margin-top: 12px;
        overflow: visible;
        padding-bottom: 0;
    }

    .status-step {
        position: relative;
        min-height: 68px;
        padding: 11px 12px 11px 52px;
        border-radius: 15px;
        background: rgba(7, 19, 38, 0.48);
        border: 1px solid rgba(120, 160, 255, 0.12);
        display: block;
    }

        .status-step::before {
            content: "";
            position: absolute;
            left: 14px;
            top: 15px;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            display: block;
            background: rgba(143, 166, 200, 0.22);
            border: 1px solid rgba(143, 166, 200, 0.34);
        }

        .status-step::after {
            content: "";
            position: absolute;
            left: 26px;
            top: 44px;
            width: 2px;
            height: calc(100% - 24px);
            background: rgba(120, 160, 255, 0.16);
        }

        .status-step:last-child::after {
            display: none;
        }

        .status-step.done {
            border-color: rgba(50, 213, 131, 0.35);
            background: rgba(50, 213, 131, 0.08);
        }

            .status-step.done::before {
                background: #32d583;
                border-color: #32d583;
                box-shadow: 0 0 16px rgba(50, 213, 131, 0.45);
            }

            .status-step.done::after {
                background: rgba(50, 213, 131, 0.35);
            }

        .status-step.current {
            border-color: rgba(80, 160, 255, 0.75);
            background: rgba(13, 110, 253, 0.16);
            box-shadow: 0 0 22px rgba(13, 110, 253, 0.18);
        }

            .status-step.current::before {
                background: #1e8bff;
                border-color: #6fb4ff;
                box-shadow: 0 0 18px rgba(30, 139, 255, 0.55);
            }

    .status-step-title {
        color: #ffffff;
        font-size: 13px;
        font-weight: 850;
        line-height: 1.25;
    }

    .status-step-caption {
        margin-top: 4px;
        color: #9fb3d9;
        font-size: 12px;
        line-height: 1.35;
    }

    .client-status-message {
        margin-top: 12px;
        padding: 13px;
        border-radius: 15px;
        background: rgba(13, 110, 253, 0.10);
        border: 1px solid rgba(120, 160, 255, 0.16);
        color: #d8e8ff;
        line-height: 1.42;
    }

        .client-status-message strong {
            color: #ffffff;
        }

    /* адаптив карточки */
    @@media (max-width: 1050px) {
        .request-details-modal {
            width: calc(100vw - 24px);
            max-height: calc(100vh - 24px);
        }

        .request-details-body {
            grid-template-columns: 1fr;
        }

        .request-details-side {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 650px) {
        .request-details-backdrop {
            padding: 8px;
        }

        .request-details-modal {
            width: calc(100vw - 16px);
            max-height: calc(100vh - 16px);
            border-radius: 18px;
        }

        .request-details-header,
        .request-details-body,
        .request-details-footer {
            padding-left: 14px;
            padding-right: 14px;
        }

        .request-info-grid {
            grid-template-columns: 1fr;
        }

        .request-status-actions {
            grid-template-columns: 1fr;
        }

        .request-price-large {
            font-size: 30px;
        }
    }

    .summary-success {
        margin-top: 14px;
        padding: 13px 14px;
        border-radius: 14px;
        color: #d8ffe9;
        background: rgba(50, 213, 131, 0.12);
        border: 1px solid rgba(50, 213, 131, 0.28);
    }
    /* ===== PHOTO VIEWER MODAL ===== */

    .photo-viewer-backdrop {
        position: fixed;
        inset: 0;
        z-index: 3000;
        background: rgba(3, 12, 27, 0.88);
        backdrop-filter: blur(8px);
        display: grid;
        place-items: center;
        padding: 24px;
    }

    .photo-viewer-modal {
        width: min(1100px, calc(100vw - 48px));
        max-height: calc(100vh - 48px);
        border-radius: 24px;
        background: rgba(7, 19, 38, 0.98);
        border: 1px solid rgba(120, 160, 255, 0.22);
        box-shadow: 0 32px 90px rgba(0, 0, 0, 0.65);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .photo-viewer-header {
        padding: 16px 20px;
        border-bottom: 1px solid rgba(120, 160, 255, 0.14);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

        .photo-viewer-header strong {
            color: #ffffff;
            font-size: 18px;
        }

    .photo-viewer-close {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        border: 1px solid rgba(120, 160, 255, 0.18);
        background: rgba(255, 255, 255, 0.04);
        color: #ffffff;
        font-size: 26px;
        line-height: 1;
    }

    .photo-viewer-body {
        padding: 18px;
        min-height: 0;
        display: grid;
        place-items: center;
        overflow: auto;
    }

        .photo-viewer-body img {
            max-width: 100%;
            max-height: calc(100vh - 170px);
            object-fit: contain;
            border-radius: 16px;
            background: rgba(3, 12, 27, 0.9);
        }

    @@media (max-width: 650px) {
        .photo-viewer-backdrop {
            padding: 10px;
        }

        .photo-viewer-modal {
            width: calc(100vw - 20px);
            max-height: calc(100vh - 20px);
            border-radius: 18px;
        }
    }

    .section-svg-icon {
        width: 38px;
        height: 38px;
        flex: 0 0 auto;
        display: inline-grid;
        place-items: center;
        border-radius: 13px;
        color: #bfdbfe;
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.24), rgba(124, 58, 237, 0.16)), rgba(13, 110, 253, 0.10);
        border: 1px solid rgba(147, 197, 253, 0.22);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }

        .section-svg-icon svg {
            width: 20px;
            height: 20px;
            display: block;
            stroke: currentColor;
            fill: none;
            stroke-width: 2.2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .summary-svg-icon {
        width: 38px;
        height: 38px;
        flex: 0 0 auto;
        display: inline-grid;
        place-items: center;
        border-radius: 13px;
        color: #bfdbfe;
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.24), rgba(124, 58, 237, 0.16)), rgba(13, 110, 253, 0.10);
        border: 1px solid rgba(147, 197, 253, 0.22);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }

        .summary-svg-icon svg {
            width: 20px;
            height: 20px;
            display: block;
            stroke: currentColor;
            fill: none;
            stroke-width: 2.1;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    /* ===== REQUEST TABLE ACTIONS ===== */

    .request-table-actions {
        display: grid;
        grid-template-columns: 1fr;
        gap: 8px;
        width: 92px;
        align-items: stretch;
    }

    .request-table-action {
        min-height: 34px;
        padding: 0 12px;
        border-radius: 12px;
        border: 1px solid rgba(120, 160, 255, 0.22);
        background: rgba(24, 40, 68, 0.72);
        color: #dbeafe;
        font-size: 13px;
        font-weight: 850;
        line-height: 1;
        transition: 0.16s ease;
    }

        .request-table-action:hover {
            transform: translateY(-1px);
            color: #ffffff;
            border-color: rgba(80, 160, 255, 0.72);
            background: rgba(31, 54, 91, 0.96);
        }

    .request-table-action-primary {
        border-color: rgba(96, 165, 250, 0.34);
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.22), rgba(124, 58, 237, 0.10)), rgba(24, 40, 68, 0.76);
    }

    .request-table-action-secondary {
        border-color: rgba(147, 197, 253, 0.22);
    }

    .request-table-action-danger {
        color: #ffd1da;
        border-color: rgba(255, 77, 109, 0.32);
        background: rgba(255, 77, 109, 0.10);
    }

        .request-table-action-danger:hover {
            color: #ffffff;
            border-color: rgba(255, 77, 109, 0.58);
            background: rgba(255, 77, 109, 0.18);
        }

    .table td:last-child,
    .table th:last-child {
        width: 110px;
        min-width: 110px;
    }
    /* ===== LIGHT THEME: REPAIR REQUEST SUMMARY GLASS ===== */

    body.light-theme .repair-summary-card {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.46), rgba(255, 255, 255, 0.20)) !important;
        border: 1px solid rgba(31, 70, 130, 0.14) !important;
        box-shadow: 0 22px 58px rgba(31, 70, 130, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.72) !important;
        backdrop-filter: blur(22px) saturate(1.18) !important;
        -webkit-backdrop-filter: blur(22px) saturate(1.18) !important;
    }

    body.light-theme .summary-title h3 {
        color: #102033 !important;
    }

    body.light-theme .summary-title p {
        color: #64748b !important;
    }

    body.light-theme .summary-price {
        margin: 18px 0;
        padding: 16px 18px;
        border-radius: 18px;
        color: #118a52 !important;
        background: linear-gradient(135deg, rgba(220, 252, 231, 0.54), rgba(255, 255, 255, 0.20)) !important;
        border: 1px solid rgba(34, 197, 94, 0.18) !important;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.62), 0 12px 28px rgba(21, 128, 61, 0.08) !important;
    }

    body.light-theme .summary-empty,
    body.light-theme .summary-hint,
    body.light-theme .summary-breakdown div {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.16)) !important;
        border: 1px solid rgba(31, 70, 130, 0.13) !important;
        color: #243b5a !important;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.58), 0 10px 24px rgba(31, 70, 130, 0.06) !important;
        backdrop-filter: blur(14px) saturate(1.10) !important;
        -webkit-backdrop-filter: blur(14px) saturate(1.10) !important;
    }

        body.light-theme .summary-empty,
        body.light-theme .summary-hint span,
        body.light-theme .summary-breakdown span {
            color: #64748b !important;
        }

        body.light-theme .summary-hint strong,
        body.light-theme .summary-breakdown strong {
            color: #102033 !important;
        }

    body.light-theme .summary-error {
        color: #be123c !important;
        background: linear-gradient(135deg, rgba(255, 228, 230, 0.68), rgba(255, 255, 255, 0.22)) !important;
        border: 1px solid rgba(244, 63, 94, 0.24) !important;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.58), 0 10px 24px rgba(190, 18, 60, 0.08) !important;
    }

    body.light-theme .summary-actions {
        display: grid;
        gap: 12px;
    }

        body.light-theme .summary-actions .btn-outline-primary,
        body.light-theme .summary-actions .btn-outline-secondary,
        body.light-theme .summary-actions .btn-outline-dark {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.46), rgba(255, 255, 255, 0.18)) !important;
            border: 1px solid rgba(31, 70, 130, 0.18) !important;
            color: #1f3a5f !important;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.62), 0 10px 24px rgba(31, 70, 130, 0.07) !important;
        }

            body.light-theme .summary-actions .btn-outline-primary:hover,
            body.light-theme .summary-actions .btn-outline-secondary:hover,
            body.light-theme .summary-actions .btn-outline-dark:hover {
                background: linear-gradient(135deg, rgba(219, 234, 254, 0.62), rgba(255, 255, 255, 0.26)) !important;
                border-color: rgba(37, 99, 235, 0.32) !important;
                color: #0f172a !important;
            }

        body.light-theme .summary-actions .btn-primary {
            color: #ffffff !important;
            background: linear-gradient(135deg, #2563eb, #7c3aed) !important;
            border-color: rgba(37, 99, 235, 0.34) !important;
            box-shadow: 0 16px 34px rgba(37, 99, 235, 0.22) !important;
        }

    /* ===== MULTI SELECT DAMAGE MAP FIX ===== */

    .damage-part-item {
        position: relative;
    }

        .damage-part-item.active {
            border-color: rgba(50, 213, 131, 0.95) !important;
            background: rgba(13, 110, 253, 0.24) !important;
            color: #ffffff !important;
            box-shadow: 0 0 0 1px rgba(50, 213, 131, 0.20), 0 0 20px rgba(50, 213, 131, 0.18) !important;
        }

    .part-check {
        margin-left: auto;
        width: 22px;
        height: 22px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #22c55e);
        color: #ffffff;
        font-size: 13px;
        font-weight: 900;
        box-shadow: 0 0 14px rgba(34, 197, 94, 0.28);
    }

    .svg-zone-v2.active {
        opacity: 1 !important;
        stroke: #32d583 !important;
        stroke-width: 2.6 !important;
        filter: drop-shadow(0 0 12px rgba(50, 213, 131, 0.46)) brightness(1.15) !important;
    }

    body.light-theme .damage-part-item.active {
        color: #0f172a !important;
        background: linear-gradient(135deg, rgba(191, 219, 254, 0.72), rgba(220, 252, 231, 0.32)) !important;
        border-color: rgba(34, 197, 94, 0.48) !important;
        box-shadow: 0 0 0 1px rgba(34, 197, 94, 0.14), 0 14px 30px rgba(37, 99, 235, 0.10), inset 0 1px 0 rgba(255, 255, 255, 0.72) !important;
    }


    /* ===== DAMAGE CART: PER-DETAIL EDITOR ===== */

    .damage-cart-item.damage-cart-item-editable {
        grid-template-columns: minmax(190px, 1fr) minmax(420px, 1.8fr) auto 42px;
        align-items: end;
    }

    .damage-cart-title strong {
        display: block;
        color: #ffffff;
    }

    .damage-cart-title span {
        display: block;
        margin-top: 4px;
        color: #9fb3d9;
        font-size: 13px;
        line-height: 1.35;
    }

    .damage-cart-editor {
        display: grid;
        grid-template-columns: minmax(130px, 1fr) minmax(130px, 1fr) minmax(120px, 1fr);
        gap: 10px;
        align-items: end;
    }

        .damage-cart-editor label {
            display: block;
            margin-bottom: 5px;
            color: #9fb3d9;
            font-size: 12px;
            font-weight: 800;
        }

    .damage-cart-select {
        min-height: 38px !important;
        padding: 0 10px !important;
        border-radius: 12px !important;
        font-size: 13px !important;
        font-weight: 750 !important;
    }

    body.light-theme .damage-cart-title strong {
        color: #102033 !important;
    }

    body.light-theme .damage-cart-title span,
    body.light-theme .damage-cart-editor label {
        color: #64748b !important;
    }

    body.light-theme .damage-cart-select {
        background: rgba(255, 255, 255, 0.66) !important;
        color: #102033 !important;
        border-color: rgba(31, 70, 130, 0.18) !important;
    }

    @@media (max-width: 1200px) {
        .damage-cart-item.damage-cart-item-editable {
            grid-template-columns: 1fr;
        }

        .damage-cart-editor {
            grid-template-columns: 1fr;
        }

        .damage-cart-price {
            justify-self: start;
        }
    }

</style>

<div class="repair-page">

    <section class="repair-workspace">
        <div class="repair-section-header">
            <div>
                <span class="section-kicker">Новая оценка ремонта</span>
                <h2>Параметры автомобиля и повреждения</h2>
                <p>Заполните данные клиента, выберите автомобиль и одну или несколько повреждённых деталей.</p>
            </div>

            <div class="repair-step-pill">
                <span>1</span>
                Автомобиль и повреждения
            </div>
        </div>

        <div class="repair-grid">
            <div class="repair-main-card">
                <div class="repair-card-title">
                    <span class="section-svg-icon">
                        <svg viewBox="0 0 24 24">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M5 21a7 7 0 0 1 14 0" />
                        </svg>
                    </span>
                    <h3>Данные клиента</h3>
                </div>

                <div class="repair-form-grid three">
                    <div>
                        <label class="form-label">Имя клиента</label>
                        <input class="form-control" @bind="newRequest.ClientName" placeholder="Например: Иван Петров" />
                    </div>

                    <div>
                        <label class="form-label">Телефон</label>
                        <input class="form-control" @bind="newRequest.Phone" placeholder="+7 900 000 00 00" />
                    </div>

                    @if (UserState.CanChangeRequestStatus)
                    {
                        <div>
                            <label class="form-label">Статус</label>
                            <select class="form-select" @bind="newRequest.Status">
                                <option>Новая</option>
                                <option>В обработке</option>
                                <option>Оценена</option>
                                <option>Завершена</option>
                            </select>
                        </div>
                    }
                    else
                    {
                        <div>
                            <label class="form-label">Статус</label>
                            <input class="form-control" value="Новая" readonly />
                        </div>
                    }
                </div>

                <div class="repair-divider"></div>

                <div class="repair-card-title">
                    <span class="section-svg-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M4 13l2-5h12l2 5" />
                            <path d="M5 13h14v5H5z" />
                            <circle cx="8" cy="18" r="2" />
                            <circle cx="16" cy="18" r="2" />
                        </svg>
                    </span>
                    <h3>Автомобиль</h3>
                </div>

                <div class="repair-form-grid four">
                    <div>
                        <label class="form-label">Марка авто</label>
                        <select class="form-select" value="@selectedBrand" @onchange="OnBrandChanged">
                            <option value="">Выберите марку</option>
                            @foreach (var brand in brands)
                            {
                                <option value="@brand">@brand</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Модель</label>
                        <select class="form-select"
                                value="@selectedModel"
                                @onchange="OnModelChanged"
                                disabled="@string.IsNullOrEmpty(selectedBrand)">
                            <option value="">Выберите модель</option>
                            @foreach (var model in models)
                            {
                                <option value="@model">@model</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Поколение</label>
                        <select class="form-select"
                                value="@selectedGeneration"
                                @onchange="OnGenerationChanged"
                                disabled="@string.IsNullOrEmpty(selectedModel)">
                            <option value="">Выберите поколение</option>
                            @foreach (var generation in generations)
                            {
                                <option value="@generation.Generation">
                                    @generation.Generation (@generation.StartYear–@generation.EndYear)
                                </option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Год выпуска</label>
                        <select class="form-select"
                                value="@selectedYear"
                                @onchange="OnYearChanged"
                                disabled="@string.IsNullOrEmpty(selectedGeneration)">
                            <option value="0">Выберите год</option>
                            @foreach (var year in years)
                            {
                                <option value="@year">@year</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="repair-divider"></div>

                <div class="repair-card-title">
                    <span class="section-svg-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L4 17v3h3l5.3-5.3a4 4 0 0 0 5.4-5.4" />
                            <path d="M15 5l4 4" />
                        </svg>
                    </span>
                    <h3>Повреждение</h3>
                </div>

                <div class="repair-form-grid three">
                    <div>
                        <label class="form-label">Повреждённая деталь</label>
                        <input class="form-control"
                               value="@GetSelectedPartsText()"
                               readonly />
                    </div>

                    <div>
                        <label class="form-label">Тип ремонта</label>
                        <select class="form-select" @bind="newRequest.RepairType">
                            <option value="">Выберите тип</option>
                            <option>Ремонт</option>
                            <option>Покраска</option>
                            <option>Замена</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Степень повреждения</label>
                        <select class="form-select" @bind="newRequest.DamageLevel">
                            <option value="">Выберите степень</option>
                            <option>Лёгкое</option>
                            <option>Среднее</option>
                            <option>Сильное</option>
                        </select>
                    </div>
                </div>

                <div class="damage-type-row">
                    <button type="button"
                            class="@GetDamagePresetClass("Царапина")"
                            disabled="@IsDamagePresetDisabled("Царапина")"
                            @onclick='() => SelectDamagePreset("Царапина", "Замена", "Лёгкое")'>
                        🟣 Царапина
                    </button>

                    <button type="button"
                            class="@GetDamagePresetClass("Вмятина")"
                            disabled="@IsDamagePresetDisabled("Вмятина")"
                            @onclick='() => SelectDamagePreset("Вмятина", "Ремонт", "Среднее")'>
                        🔵 Вмятина
                    </button>

                    <button type="button"
                            class="@GetDamagePresetClass("Скол")"
                            disabled="@IsDamagePresetDisabled("Скол")"
                            @onclick='() => SelectDamagePreset("Скол", "Замена", "Лёгкое")'>
                        🟢 Скол
                    </button>

                    <button type="button"
                            class="@GetDamagePresetClass("Трещина")"
                            disabled="@IsDamagePresetDisabled("Трещина")"
                            @onclick='() => SelectDamagePreset("Трещина", "Ремонт", "Среднее")'>
                        🟡 Трещина
                    </button>

                    <button type="button"
                            class="@GetDamagePresetClass("Коррозия")"
                            disabled="@IsDamagePresetDisabled("Коррозия")"
                            @onclick='() => SelectDamagePreset("Коррозия", "Покраска", "Среднее")'>
                        🟠 Коррозия
                    </button>

                    <button type="button"
                            class="@GetDamagePresetClass("Замена детали")"
                            disabled="@IsDamagePresetDisabled("Замена детали")"
                            @onclick='() => SelectDamagePreset("Замена детали", "Замена", "Сильное")'>
                        🔴 Замена детали
                    </button>
                </div>
                <div class="damage-cart-actions">
                    <button type="button"
                            class="btn btn-primary"
                            @onclick="AddDamageToCart">
                        ➕ Добавить повреждение
                    </button>



                    <button type="button"
                            class="btn btn-outline-secondary"
                            @onclick="ClearDamageSelection">
                        Очистить выбор
                    </button>
                </div>
                <div class="damage-cart-panel">
                    <div class="damage-cart-header">
                        <div>
                            <h3>Корзина повреждений</h3>
                            <p>Каждая деталь может иметь свой тип повреждения и отдельный расчёт.</p>
                        </div>

                        <strong>@damageCart.Count</strong>
                    </div>

                    @if (damageCart.Count == 0)
                    {
                        <div class="damage-cart-empty">
                            Повреждения пока не добавлены. Выберите деталь, тип повреждения и нажмите “Добавить повреждение”.
                        </div>
                    }
                    else
                    {
                        <div class="damage-cart-list">
                            @foreach (var item in damageCart)
                            {
                                <div class="damage-cart-item damage-cart-item-editable">
                                    <div class="damage-cart-title">
                                        <strong>@item.PartName</strong>
                                        <span>Настройте тип повреждения, ремонт и степень именно для этой детали.</span>
                                    </div>

                                    <div class="damage-cart-editor">
                                        <div>
                                            <label>Повреждение</label>
                                            <select class="form-select damage-cart-select"
                                                    value="@item.DamagePreset"
                                                    @onchange="async (e) => await OnCartDamagePresetChanged(item, e)">
                                                @foreach (var preset in GetDamagePresetOptionsForPart(item.PartName))
                                                {
                                                    <option value="@preset">@preset</option>
                                                }
                                            </select>
                                        </div>

                                        <div>
                                            <label>Тип ремонта</label>
                                            <select class="form-select damage-cart-select"
                                                    value="@item.RepairType"
                                                    @onchange="async (e) => await OnCartRepairTypeChanged(item, e)">
                                                @foreach (var repairType in repairTypeOptions)
                                                {
                                                    <option value="@repairType">@repairType</option>
                                                }
                                            </select>
                                        </div>

                                        <div>
                                            <label>Степень</label>
                                            <select class="form-select damage-cart-select"
                                                    value="@item.DamageLevel"
                                                    @onchange="async (e) => await OnCartDamageLevelChanged(item, e)">
                                                @foreach (var damageLevel in damageLevelOptions)
                                                {
                                                    <option value="@damageLevel">@damageLevel</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <div class="damage-cart-price">
                                        @item.Cost.ToString("N0") ₽
                                    </div>

                                    <button type="button"
                                            class="damage-cart-remove"
                                            @onclick="() => RemoveDamageFromCart(item)">
                                        🗑
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="damage-map-panel">
                    <div class="damage-map-header">
                        <div>
                            <h3>Карта повреждений кузова</h3>
                            <p>Выберите один или несколько повреждённых элементов на схеме автомобиля.</p>
                        </div>

                        <div class="selected-damage-info selected-damage-info-list">
                            <span>Выбрано:</span>

                            @if (selectedDamageParts.Count == 0)
                            {
                                <strong>не выбрано</strong>
                            }
                            else
                            {
                                <div class="selected-parts-list">
                                    @foreach (var part in selectedDamageParts)
                                    {
                                        <button type="button"
                                                class="selected-part-pill"
                                                @onclick="() => SelectDamagePart(part)">
                                            @part
                                            <span>×</span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="body-type-tabs">
                        <button type="button"
                                class="@GetBodyTypeClass("Седан")"
                                @onclick='() => SelectBodyType("Седан")'>
                            🚘 Седан
                        </button>

                        <button type="button"
                                class="@GetBodyTypeClass("Хэтчбек")"
                                @onclick='() => SelectBodyType("Хэтчбек")'>
                            🚗 Хэтчбек
                        </button>

                        <button type="button"
                                class="@GetBodyTypeClass("SUV")"
                                @onclick='() => SelectBodyType("SUV")'>
                            🚙 SUV
                        </button>

                        <button type="button"
                                class="@GetBodyTypeClass("Универсал")"
                                @onclick='() => SelectBodyType("Универсал")'>
                            🚐 Универсал
                        </button>

                        <button type="button"
                                class="@GetBodyTypeClass("Купе")"
                                @onclick='() => SelectBodyType("Купе")'>
                            🏎️ Купе
                        </button>
                    </div>

                    <div class="damage-map-layout">
                        <div class="damage-parts-list">
                            @foreach (var part in GetDamagePartOptions())
                            {
                                <button type="button"
                                        class="@GetPartListClass(part)"
                                        @onclick="() => SelectDamagePart(part)">
                                    <span class="@GetPartDotClass(part)"></span>
                                    <span>@part</span>

                                    @if (selectedDamageParts.Contains(part))
                                    {
                                        <span class="part-check">✓</span>
                                    }
                                </button>
                            }
                        </div>

                        <div class="vehicle-map-card vehicle-map-card-v2">
                            <div class="vehicle-map-toolbar">
                                <span>Тип кузова: <strong>@selectedBodyType</strong></span>
                                <span>Профессиональная схема кузовных зон</span>
                            </div>

