    private async Task AddDamageToCart()
    {
        errorMessage = "";
        successMessage = "";

        if (selectedDamageParts.Count == 0)
        {
            errorMessage = "Выберите одну или несколько повреждённых деталей на схеме.";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedDamagePreset))
