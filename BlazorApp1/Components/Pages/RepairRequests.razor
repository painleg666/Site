@page "/repair-requests"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MyBlazorSite.Data
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure

@inject IWebHostEnvironment Env
@inject AppDbContext Db
@inject IJSRuntime JS
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header">
            <h3 class="mb-0">Оценка стоимости кузовного ремонта после ДТП</h3>
        </div>

        <div class="card-body">
            <h5>Новая заявка</h5>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label class="form-label">Имя клиента</label>
                    <input class="form-control" @bind="newRequest.ClientName" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Телефон</label>
                    <input class="form-control" @bind="newRequest.Phone" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Статус</label>
                    <select class="form-select" @bind="newRequest.Status">
                        <option>Новая</option>
                        <option>В обработке</option>
                        <option>Оценена</option>
                        <option>Завершена</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Марка авто</label>
                    <select class="form-select" value="@selectedBrand" @onchange="OnBrandChanged">
                        <option value="">Выберите марку</option>
                        @foreach (var brand in brands)
                        {
                            <option value="@brand">@brand</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Модель</label>
                    <select class="form-select"
                            value="@selectedModel"
                            @onchange="OnModelChanged"
                            disabled="@string.IsNullOrEmpty(selectedBrand)">
                        <option value="">Выберите модель</option>
                        @foreach (var model in models)
                        {
                            <option value="@model">@model</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Поколение</label>
                    <select class="form-select"
                            value="@selectedGeneration"
                            @onchange="OnGenerationChanged"
                            disabled="@string.IsNullOrEmpty(selectedModel)">
                        <option value="">Выберите поколение</option>
                        @foreach (var generation in generations)
                        {
                            <option value="@generation.Generation">
                                @generation.Generation (@generation.StartYear–@generation.EndYear)
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Год выпуска</label>
                    <select class="form-select"
                            value="@selectedYear"
                            @onchange="OnYearChanged"
                            disabled="@string.IsNullOrEmpty(selectedGeneration)">
                        <option value="0">Выберите год</option>
                        @foreach (var year in years)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Повреждённая деталь</label>
                    <select class="form-select" @bind="newRequest.DamagedPart">
                        <option value="">Выберите деталь</option>
                        <option>Передний бампер</option>
                        <option>Задний бампер</option>
                        <option>Капот</option>
                        <option>Дверь</option>
                        <option>Крыло</option>
                        <option>Фара</option>
                        <option>Крышка багажника</option>
                        <option>Порог</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Тип ремонта</label>
                    <select class="form-select" @bind="newRequest.RepairType">
                        <option value="">Выберите тип</option>
                        <option>Ремонт</option>
                        <option>Покраска</option>
                        <option>Замена</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Степень повреждения</label>
                    <select class="form-select" @bind="newRequest.DamageLevel">
                        <option value="">Выберите степень</option>
                        <option>Лёгкое</option>
                        <option>Среднее</option>
                        <option>Сильное</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Фото повреждения</label>

                    <input id="repairPhotoInput"
                           class="form-control"
                           type="file"
                           accept=".jpg,.jpeg,.png,.webp"
                           onchange="uploadRepairPhoto(this)" />

                    <input id="repairPhotoPath" type="hidden" />

                    <small id="repairPhotoMessage" class="text-muted"></small>

                    @* <div class="mt-2">
                        <img id="repairPhotoPreview"
                             src=""
                             alt="Фото повреждения"
                             style="display:none; width:120px; height:90px; object-fit:cover; border-radius:8px;" />
                    </div> *@
                </div>

                <div class="col-12">
                    <div class="alert alert-secondary">
                        <div>
                            Предварительная стоимость:
                            <strong>@previewCost ₽</strong>
                        </div>

                        @if (previewCost > 0)
                        {
                            <div class="small text-muted mt-2">
                                Базовая цена работы: <strong>@previewBasePrice ₽</strong>
                                <br />
                                Коэффициент повреждения "@newRequest.DamageLevel":
                                x@(previewDamageMultiplier.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))
                                <br />
                                Коэффициент марки @newRequest.CarBrand:
                                x@(previewBrandMultiplier.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))
                                <br />
                                Формула:
                                @previewBasePrice × @previewDamageMultiplier × @previewBrandMultiplier = <strong>@previewCost ₽</strong>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="alert alert-danger mt-2 mb-0">
                                @errorMessage
                            </div>
                        }
                    </div>
                </div>

                <div class="col-12">
                    <button class="btn btn-outline-secondary me-2" @onclick="UpdatePreviewCost">
                        Рассчитать стоимость
                    </button>

                    <button class="btn btn-primary" @onclick="AddRequest">
                        Рассчитать и сохранить заявку
                    </button>
                </div>
            </div>

            <hr />

            <h5>Список заявок</h5>

            <div class="row g-3 mb-3">
                <div class="col-md-5">
                    <input class="form-control"
                           placeholder="Поиск по имени, телефону, марке или модели"
                           @bind="searchText" />
                </div>

                <div class="col-md-3">
                    <select class="form-select" @bind="statusFilter">
                        <option value="">Все статусы</option>
                        <option>Новая</option>
                        <option>В обработке</option>
                        <option>Оценена</option>
                        <option>Завершена</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <button class="btn btn-outline-primary w-100" @onclick="LoadRequests">
                        Применить
                    </button>
                </div>

                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters">
                        Сбросить
                    </button>
                </div>
            </div>

            @if (requests.Count == 0)
            {
                <div class="alert alert-info">Заявок пока нет.</div>
            }
            else
            {
                <div class="table-responsive-mobile">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Клиент</th>
                                <th>Авто</th>
                                <th>Повреждение</th>
                                <th>Фото</th>
                                <th>Стоимость</th>
                                <th>Статус</th>
                                <th>Дата</th>
                                <th>Действия</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in requests)
                            {
                                <tr>
                                    <td>@item.Id</td>

                                    <td>
                                        @item.ClientName<br />
                                        <small class="text-muted">@item.Phone</small>
                                    </td>

                                    <td>
                                        @item.CarBrand @item.CarModel
                                        <br />
                                        <small class="text-muted">
                                            @item.CarGeneration, @item.CarYear г.
                                        </small>
                                    </td>

                                    <td>
                                        @item.DamagedPart<br />
                                        <small class="text-muted">
                                            @item.RepairType, @item.DamageLevel
                                        </small>
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.PhotoPath))
                                        {
                                            <img src="@item.PhotoPath"
                                                 alt="Фото повреждения"
                                                 style="width: 90px; height: 70px; object-fit: cover; border-radius: 8px;" />
                                        }
                                        else
                                        {
                                            <span class="text-muted">Нет фото</span>
                                        }
                                    </td>

                                    <td>
                                        <strong>@item.CalculatedCost ₽</strong>
                                    </td>

                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge @GetStatusBadgeClass(item.Status)">
                                                @item.Status
                                            </span>

                                            <select class="form-select form-select-sm"
                                                    style="max-width: 170px;"
                                                    value="@item.Status"
                                                    @onchange='async e => await UpdateStatus(item.Id, e.Value?.ToString() ?? "")'>
                                                <option>Новая</option>
                                                <option>В обработке</option>
                                                <option>Оценена</option>
                                                <option>Завершена</option>
                                            </select>
                                        </div>
                                    </td>

                                    <td>
                                        @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                    </td>

                                    <td>
                                        <button class="btn btn-outline-dark btn-sm me-2"
                                                @onclick="() => DownloadPdf(item.Id)">
                                            PDF
                                        </button>

                                        <button class="btn btn-danger btn-sm"
                                                @onclick="() => DeleteRequest(item.Id)">
                                            Удалить
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<CarModelGeneration> carCatalog = new();

    private List<string> brands = new();
    private List<string> models = new();
    private List<CarModelGeneration> generations = new();
    private List<int> years = new();

    private string selectedBrand = string.Empty;
    private string selectedModel = string.Empty;
    private string selectedGeneration = string.Empty;
    private int selectedYear;

    private string errorMessage = "";
    private string searchText = "";
    private string statusFilter = "";
    private decimal previewCost;
    private decimal previewBasePrice;
    private decimal previewDamageMultiplier;
    private decimal previewBrandMultiplier;
    private List<RepairRequest> requests = new();

    private RepairRequest newRequest = new()
    {
        CarYear = DateTime.Now.Year,
        Status = "Новая"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadRequests();

        await using var db = await DbFactory.CreateDbContextAsync();

        carCatalog = await db.CarModelGenerations
            .OrderBy(x => x.Brand)
            .ThenBy(x => x.Model)
            .ThenBy(x => x.StartYear)
            .ToListAsync();

        brands = carCatalog
            .Select(x => x.Brand)
            .Distinct()
            .OrderBy(x => x)
            .ToList();
    }

    private async Task ResetFilters()
    {
        searchText = "";
        statusFilter = "";

        await LoadRequests();
    }

    private async Task UpdatePreviewCost()
    {
        errorMessage = "";

        await using var db = await DbFactory.CreateDbContextAsync();

        var priceItem = await db.RepairPriceItems
            .FirstOrDefaultAsync(x =>
                x.PartName == newRequest.DamagedPart &&
                x.RepairType == newRequest.RepairType);

        if (priceItem is null)
        {
            previewCost = 0;
            previewBasePrice = 0;
            previewDamageMultiplier = 0;
            previewBrandMultiplier = 0;
            previewBasePrice = 0;
            previewDamageMultiplier = 0;
            previewBrandMultiplier = 0;

            errorMessage = "Не удалось рассчитать стоимость. Проверьте выбранные параметры и прайс-лист.";
            return;
        }

        previewBasePrice = priceItem.BasePrice;
        previewDamageMultiplier = GetDamageMultiplier(newRequest.DamageLevel);
        previewBrandMultiplier = GetBrandMultiplier(newRequest.CarBrand);

        previewCost = Math.Round(previewBasePrice * previewDamageMultiplier * previewBrandMultiplier, 0);

        if (previewCost <= 0)
        {
            errorMessage = "Не удалось рассчитать стоимость. Проверьте выбранные параметры и прайс-лист.";
        }
    }

    private void OnBrandChanged(ChangeEventArgs e)
    {
        selectedBrand = e.Value?.ToString() ?? string.Empty;

        selectedModel = string.Empty;
        selectedGeneration = string.Empty;
        selectedYear = 0;

        models = carCatalog
            .Where(x => x.Brand == selectedBrand)
            .Select(x => x.Model)
            .Distinct()
            .OrderBy(x => x)
            .ToList();

        generations.Clear();
        years.Clear();

        newRequest.CarBrand = selectedBrand;
        newRequest.CarModel = string.Empty;
        newRequest.CarGeneration = string.Empty;
        newRequest.CarYear = 0;
    }



    private void OnModelChanged(ChangeEventArgs e)
    {
        selectedModel = e.Value?.ToString() ?? string.Empty;

        selectedGeneration = string.Empty;
        selectedYear = 0;

        generations = carCatalog
            .Where(x => x.Brand == selectedBrand && x.Model == selectedModel)
            .OrderBy(x => x.StartYear)
            .ToList();

        years.Clear();

        newRequest.CarModel = selectedModel;
        newRequest.CarGeneration = string.Empty;
        newRequest.CarYear = 0;
    }

    private void OnGenerationChanged(ChangeEventArgs e)
    {
        selectedGeneration = e.Value?.ToString() ?? string.Empty;

        var generation = generations
            .FirstOrDefault(x => x.Generation == selectedGeneration);

        years.Clear();

        if (generation != null)
        {
            years = Enumerable.Range(
                    generation.StartYear,
                    generation.EndYear - generation.StartYear + 1
                )
                .OrderByDescending(x => x)
                .ToList();
        }

        selectedYear = 0;

        newRequest.CarGeneration = selectedGeneration;
        newRequest.CarYear = 0;
    }

    private void OnYearChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int year))
        {
            selectedYear = year;
            newRequest.CarYear = year;
        }
    }

    private async Task LoadRequests()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var query = db.RepairRequests.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            query = query.Where(x =>
                x.ClientName.Contains(searchText) ||
                x.Phone.Contains(searchText) ||
                x.CarBrand.Contains(searchText) ||
                x.CarModel.Contains(searchText));
        }

        if (!string.IsNullOrWhiteSpace(statusFilter))
        {
            query = query.Where(x => x.Status == statusFilter);
        }

        requests = await query
            .OrderByDescending(x => x.Id)
            .ToListAsync();
    }

    private async Task<decimal> CalculateCurrentCostAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var priceItem = await db.RepairPriceItems
            .FirstOrDefaultAsync(x =>
                x.PartName == newRequest.DamagedPart &&
                x.RepairType == newRequest.RepairType);

        if (priceItem is null)
            return 0;

        decimal damageMultiplier = GetDamageMultiplier(newRequest.DamageLevel);
        decimal brandMultiplier = GetBrandMultiplier(newRequest.CarBrand);

        return Math.Round(priceItem.BasePrice * damageMultiplier * brandMultiplier, 0);
    }

    private decimal GetBrandMultiplier(string brand)
    {
        return brand switch
        {
            "LADA" => 1.0m,
            "Renault" => 1.0m,
            "Hyundai" => 1.0m,
            "Kia" => 1.0m,

            "Chery" => 1.1m,
            "Haval" => 1.1m,

            "Toyota" => 1.2m,
            "Volkswagen" => 1.2m,
            "Skoda" => 1.2m,

            "BMW" => 1.6m,
            "Mercedes-Benz" => 1.6m,

            _ => 1.0m
        };
    }

    private decimal GetDamageMultiplier(string damageLevel)
    {
        return damageLevel switch
        {
            "Лёгкое" => 1.0m,
            "Среднее" => 1.5m,
            "Сильное" => 2.2m,
            _ => 0
        };
    }

    private async Task AddRequest()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(newRequest.ClientName))
        {
            errorMessage = "Введите имя клиента.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.CarBrand))
        {
            errorMessage = "Выберите марку автомобиля.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.CarModel))
        {
            errorMessage = "Выберите модель автомобиля.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.CarGeneration))
        {
            errorMessage = "Выберите поколение автомобиля.";
            return;
        }

        if (newRequest.CarYear <= 0)
        {
            errorMessage = "Выберите год выпуска автомобиля.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.DamagedPart))
        {
            errorMessage = "Выберите повреждённую деталь.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.RepairType))
        {
            errorMessage = "Выберите тип ремонта.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.DamageLevel))
        {
            errorMessage = "Выберите степень повреждения.";
            return;
        }

        newRequest.CalculatedCost = await CalculateCurrentCostAsync();

        if (newRequest.CalculatedCost <= 0)
        {
            errorMessage = "Не удалось рассчитать стоимость. Проверьте прайс-лист.";
            return;
        }

        // var photoPath = await SavePhotoAsync();

        // if (!string.IsNullOrWhiteSpace(errorMessage))
        // {
        //     return;
        // }

        // if (!string.IsNullOrWhiteSpace(photoPath))
        // {
        //     newRequest.PhotoPath = photoPath;
        // }
        var uploadedPhotoPath = await JS.InvokeAsync<string>("getInputValue", "repairPhotoPath");

        if (!string.IsNullOrWhiteSpace(uploadedPhotoPath))
        {
            newRequest.PhotoPath = uploadedPhotoPath;
        }
        await using var db = await DbFactory.CreateDbContextAsync();

            db.RepairRequests.Add(newRequest);
            await db.SaveChangesAsync();

        previewCost = 0;
        await JS.InvokeVoidAsync("clearRepairPhoto");
        

        newRequest = new RepairRequest
        {
            CarYear = DateTime.Now.Year,
            Status = "Новая"
        };

        selectedBrand = string.Empty;
        selectedModel = string.Empty;
        selectedGeneration = string.Empty;
        selectedYear = 0;

        models.Clear();
        generations.Clear();
        years.Clear();

        await LoadRequests();
    }

    private async Task DeleteRequest(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var request = await db.RepairRequests.FindAsync(id);

        if (request is null)
            return;

        db.RepairRequests.Remove(request);
        await db.SaveChangesAsync();

        await LoadRequests();
    }

    private async Task UpdateStatus(int id, string status)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var request = await db.RepairRequests.FindAsync(id);

        if (request is null)
            return;

        request.Status = status;

        await db.SaveChangesAsync();

        await LoadRequests();
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Новая" => "bg-primary",
            "В обработке" => "bg-warning text-dark",
            "Оценена" => "bg-success",
            "Завершена" => "bg-secondary",
            _ => "bg-dark"
        };
    }

    private async Task DownloadPdf(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var request = await db.RepairRequests.FindAsync(id);

        if (request is null)
            return;

        var pdfBytes = GeneratePdf(request);
        var base64 = Convert.ToBase64String(pdfBytes);

        await JS.InvokeVoidAsync(
            "downloadFileFromBase64",
            $"repair-request-{request.Id}.pdf",
            base64);
    }

    private byte[] GeneratePdf(RepairRequest request)
    {
        return Document.Create(container =>
        {
            container.Page(page =>
            {
                page.Margin(40);
                page.Size(PageSizes.A4);

                page.Header()
                    .Text("Оценка стоимости кузовного ремонта")
                    .FontSize(20)
                    .Bold();

                page.Content()
                    .PaddingVertical(20)
                    .Column(column =>
                    {
                        column.Spacing(10);

                        column.Item().Text($"Номер заявки: {request.Id}");
                        column.Item().Text($"Клиент: {request.ClientName}");
                        column.Item().Text($"Телефон: {request.Phone}");
                        column.Item().Text($"Автомобиль: {request.CarBrand} {request.CarModel}, {request.CarGeneration}, {request.CarYear}");
                        
                        column.Item().Text($"Повреждённая деталь: {request.DamagedPart}");
                        column.Item().Text($"Тип ремонта: {request.RepairType}");
                        column.Item().Text($"Степень повреждения: {request.DamageLevel}");
                        column.Item().Text($"Коэффициент марки: x{GetBrandMultiplier(request.CarBrand)}");
                        column.Item().Text($"Статус: {request.Status}");
                        column.Item().Text($"Дата заявки: {request.CreatedAt:dd.MM.yyyy HH:mm}");

                        column.Item()
                            .PaddingTop(15)
                            .Text($"Итоговая стоимость: {request.CalculatedCost:N0} ₽")
                            .FontSize(18)
                            .Bold();
                    });

                page.Footer()
                    .AlignCenter()
                    .Text("Документ сформирован автоматически");
            });
        }).GeneratePdf();
    }
}