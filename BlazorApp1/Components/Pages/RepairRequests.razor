    private async Task DownloadPdf(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var request = await db.RepairRequests.FindAsync(id);

        if (request is null)
            return;

        if (!UserState.CanSeeAllRequests && request.OwnerKey != UserState.UserKey)
        {
            errorMessage = "У вас нет прав на скачивание этой заявки.";
            return;
        }

        var pdfBytes = GeneratePdf(request);
        var base64 = Convert.ToBase64String(pdfBytes);

        await JS.InvokeVoidAsync(
            "downloadFileFromBase64",
            $"repair-request-{GetRequestPublicCode(request)}.pdf",
            base64);
    }

