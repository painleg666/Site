    private void ClearDamageSelection()
    {
        selectedSinglePart = string.Empty;
        selectedDamageParts.Clear();
        selectedDamagePreset = string.Empty;

        newRequest.RepairType = string.Empty;
        newRequest.DamageLevel = string.Empty;

        SyncSelectedDamageParts();
