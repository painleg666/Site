    private async Task AddRequest()
    {
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrWhiteSpace(newRequest.ClientName))
        {
            errorMessage = "Введите имя клиента.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.CarBrand))
        {
            errorMessage = "Выберите марку автомобиля.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.CarModel))
        {
            errorMessage = "Выберите модель автомобиля.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.CarGeneration))
        {
            errorMessage = "Выберите поколение автомобиля.";
            return;
        }

        if (newRequest.CarYear <= 0)
        {
            errorMessage = "Выберите год выпуска автомобиля.";
            return;
        }

        if (damageCart.Count == 0)
        {
            errorMessage = "Добавьте хотя бы одно повреждение в корзину.";
            return;
        }

        SyncCartToRequest();

        if (!UserState.CanChangeRequestStatus)
        {
            newRequest.Status = "Новая";
        }

        if (string.IsNullOrWhiteSpace(newRequest.RepairType))
        {
            errorMessage = "Выберите тип ремонта.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRequest.DamageLevel))
        {
            errorMessage = "Выберите степень повреждения.";
            return;
        }

        newRequest.CalculatedCost = await CalculateCurrentCostAsync();

        if (newRequest.CalculatedCost <= 0)
        {
            errorMessage = "Не удалось рассчитать стоимость. Проверьте прайс-лист.";
            return;
        }

        var uploadedPhotoPath = await JS.InvokeAsync<string>("getInputValue", "repairPhotoPath");

        if (!string.IsNullOrWhiteSpace(uploadedPhotoPath))
        {
            newRequest.PhotoPath = uploadedPhotoPath;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        newRequest.OwnerKey = UserState.UserKey;
        newRequest.PublicCode = await GenerateUniquePublicCodeAsync(db);

        db.RepairRequests.Add(newRequest);
        await db.SaveChangesAsync();

        var createdRequestCode = GetRequestPublicCode(newRequest);
        successMessage = $"Заявка {createdRequestCode} успешно создана. Клиент сможет посмотреть статус по коду заявки и телефону.";
        ResetPreview();

        await JS.InvokeVoidAsync("clearRepairPhoto");

        newRequest = new RepairRequest
        {
            CarYear = DateTime.Now.Year,
            Status = "Новая"
        };

        selectedBrand = string.Empty;
        selectedModel = string.Empty;
        selectedGeneration = string.Empty;
        selectedYear = 0;

        selectedBodyType = "Седан";
        selectedDamagePreset = string.Empty;
        selectedDamageParts.Clear();
        selectedSinglePart = string.Empty;
        damageCart.Clear();

        models.Clear();
        generations.Clear();
        years.Clear();

        await LoadRequests();
        await StatsNotifier.NotifyChangedAsync();
    }

    private static string GetRequestPublicCode(RepairRequest request)
    {
        return string.IsNullOrWhiteSpace(request.PublicCode)
            ? $"AE-{request.Id:000000}"
            : request.PublicCode.Trim().ToUpperInvariant();
    }

    private static string GeneratePublicCode()
    {
        const string alphabet = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
        var chars = new char[8];

        for (var i = 0; i < chars.Length; i++)
        {
            chars[i] = alphabet[RandomNumberGenerator.GetInt32(alphabet.Length)];
        }

        return $"AE-{new string(chars, 0, 4)}-{new string(chars, 4, 4)}";
    }

    private static async Task<string> GenerateUniquePublicCodeAsync(AppDbContext db)
    {
        for (var attempt = 0; attempt < 30; attempt++)
        {
            var code = GeneratePublicCode();

            var exists = await db.RepairRequests
                .AsNoTracking()
                .AnyAsync(x => x.PublicCode == code);

            if (!exists)
                return code;
        }

        throw new InvalidOperationException("Не удалось создать уникальный номер заявки. Повторите сохранение.");
    }

    private async Task DeleteRequest(int id)
    {
        if (!UserState.CanSeeAllRequests)
        {
            errorMessage = "У вас нет прав на удаление заявки.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        var request = await db.RepairRequests.FindAsync(id);

        if (request is null)
            return;

        db.RepairRequests.Remove(request);
        await db.SaveChangesAsync();
        if (selectedRequest?.Id == id)
        {
            selectedRequest = null;
        }

        await LoadRequests();
        await StatsNotifier.NotifyChangedAsync();
    }

    private async Task UpdateStatus(int id, string status)
    {
        if (!UserState.CanChangeRequestStatus)
        {
            errorMessage = "У вас нет прав на изменение статуса заявки.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        var request = await db.RepairRequests.FindAsync(id);

        if (request is null)
            return;

        request.Status = status;

        await db.SaveChangesAsync();

        await LoadRequests();
        await StatsNotifier.NotifyChangedAsync();
    }

