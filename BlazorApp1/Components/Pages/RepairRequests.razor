    private void SyncCartToRequest()
    {
        if (damageCart.Count == 0)
        {
            newRequest.DamagedPart = string.Empty;
            newRequest.RepairType = string.Empty;
            newRequest.DamageLevel = string.Empty;
            return;
        }

        // Важно: сохраняем не только название детали, но и параметры каждой позиции.
        // Это позволяет PDF-акту показывать несколько повреждений отдельными строками
        // без создания дополнительной таблицы в базе данных.
        newRequest.DamagedPart = string.Join("\n", damageCart.Select(x =>
            $"{x.PartName} — {x.DamagePreset} / {x.RepairType} / {x.DamageLevel} / {x.Cost:N0} ₽"));

        newRequest.RepairType = damageCart.Select(x => x.RepairType).Distinct().Count() == 1
            ? damageCart.First().RepairType
            : "Смешанный";

        newRequest.DamageLevel = damageCart.Select(x => x.DamageLevel).Distinct().Count() == 1
            ? damageCart.First().DamageLevel
            : "Смешанное";
    }

    private void UpdatePreviewFromCart()
    {
        previewBasePrice = damageCart.Sum(x => x.BasePrice);
        previewCost = damageCart.Sum(x => x.Cost);

        previewDamageMultiplier = 0;
