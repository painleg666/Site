    private async Task RecalculateCartItemAsync(DamageCartItem item)
    {
        errorMessage = "";
        successMessage = "";

        item.BasePrice = await GetBasePriceForPartAsync(item.PartName, item.RepairType);
        item.Cost = await CalculateSingleDamageCostAsync(item.PartName, item.RepairType, item.DamageLevel);

        if (item.Cost <= 0)
        {
            errorMessage = $"Не удалось рассчитать стоимость для детали: {item.PartName}. Проверьте прайс-лист для типа ремонта “{item.RepairType}”.";
        }

        SyncCartToRequest();
        UpdatePreviewFromCart();
    }

