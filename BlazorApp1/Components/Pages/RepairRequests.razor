    private static IContainer TableHeaderCell(IContainer container)
    {
        return container
            .Background(Colors.Blue.Darken4)
            .PaddingVertical(6)
            .PaddingHorizontal(7)
            .DefaultTextStyle(x => x.FontSize(9).Bold().FontColor(Colors.White));
    }

    private static IContainer TableBodyCell(IContainer container)
    {
        return container
            .BorderBottom(1)
            .BorderColor(Colors.Grey.Lighten2)
            .PaddingVertical(7)
            .PaddingHorizontal(7)
            .DefaultTextStyle(x => x.FontSize(9).FontColor(Colors.Grey.Darken3));
    }

