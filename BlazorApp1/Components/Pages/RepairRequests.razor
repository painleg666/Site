            return;

        if (!UserState.CanSeeAllRequests)
        {
            var ownerKey = await JS.InvokeAsync<string>("localStorage.getItem", "autoestimate_owner_key");

            if (string.IsNullOrWhiteSpace(ownerKey))
            {
                ownerKey = Guid.NewGuid().ToString("N");
                await JS.InvokeVoidAsync("localStorage.setItem", "autoestimate_owner_key", ownerKey);
