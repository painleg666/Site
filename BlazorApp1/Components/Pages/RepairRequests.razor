    private async Task ApplyPendingAiDamagesAsync()
    {
        errorMessage = "";
        successMessage = "";

        var aiItems = PendingAiDamageState.TakeItems();

        if (aiItems.Count == 0)
            return;

        var addedCount = 0;
        var fallbackCount = 0;

        foreach (var aiItem in aiItems)
        {
            var partName = NormalizeAiPartName(aiItem.DetectedPart);
            var damagePreset = NormalizeAiDamagePreset(aiItem.DamageType);
            var repairType = NormalizeAiRepairType(aiItem.RepairType);
            var damageLevel = NormalizeAiDamageLevel(aiItem.DamageLevel);

            if (string.IsNullOrWhiteSpace(partName) ||
                partName == "Не определено" ||
                repairType == "Не определено" ||
                damageLevel == "Не определено")
            {
                continue;
            }

            var basePrice = await GetBasePriceForPartAsync(partName, repairType);
            var cost = await CalculateSingleDamageCostAsync(partName, repairType, damageLevel);

            if (cost <= 0)
            {
                var fallbackRepairType = GetFallbackRepairType(repairType, damagePreset);

                basePrice = await GetBasePriceForPartAsync(partName, fallbackRepairType);
                cost = await CalculateSingleDamageCostAsync(partName, fallbackRepairType, damageLevel);

                if (cost > 0)
                {
                    repairType = fallbackRepairType;
                    fallbackCount++;
                }
            }

            if (cost <= 0 && aiItem.EstimatedCost > 0)
            {
                basePrice = aiItem.EstimatedCost;
                cost = aiItem.EstimatedCost;
                fallbackCount++;
            }

            damageCart.Add(new DamageCartItem
            {
                PartName = partName,
                DamagePreset = damagePreset,
                RepairType = repairType,
                DamageLevel = damageLevel,
                BasePrice = basePrice,
                Cost = cost
            });

            if (IsDamagePartAvailableForCurrentBody(partName) &&
                !selectedDamageParts.Contains(partName))
            {
                selectedDamageParts.Add(partName);
            }

            addedCount++;
        }

        if (addedCount == 0)
        {
            errorMessage = "AI нашёл повреждения, но их не удалось сопоставить с формой заявки.";
            return;
        }

        SyncCartToRequest();
        UpdatePreviewFromCart();

        successMessage = fallbackCount > 0
            ? $"AI-повреждения добавлены в корзину: {addedCount}. Для части позиций использован запасной тип ремонта или AI-стоимость."
            : $"AI-повреждения добавлены в корзину: {addedCount}. Проверьте данные перед сохранением заявки.";
    }

