@code {
    private DashboardStats stats = new();

    private bool showSystemModal = false;
    private bool showNotifications = false;
    

    private int NotificationCount =>
        UserState.CanSeeNotifications
            ? stats.NewRequestsCount
            : 0;

    protected override async Task OnInitializedAsync()
    {
        stats = await StatsService.GetStatsAsync();
        StatsNotifier.OnChange += RefreshStatsAsync;
    }

    private async Task RefreshStatsAsync()
    {
        stats = await StatsService.GetStatsAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        StatsNotifier.OnChange -= RefreshStatsAsync;
    }

    private string CurrentUserName =>
        string.IsNullOrWhiteSpace(UserState.UserName)
            ? "Гость"
            : UserState.UserName;

    private string CurrentUserEmail =>
        string.IsNullOrWhiteSpace(UserState.Email)
            ? "Не авторизован"
            : UserState.Email;

    private string CurrentUserRole =>
        string.IsNullOrWhiteSpace(UserState.Role)
            ? "Гость"
            : UserState.Role;

    private string CurrentUserInitials
    {
        get
        {
            if (string.IsNullOrWhiteSpace(CurrentUserName))
                return "U";

            var parts = CurrentUserName.Split(' ', StringSplitOptions.RemoveEmptyEntries);

            if (parts.Length >= 2)
                return $"{parts[0][0]}{parts[1][0]}".ToUpper();

            return CurrentUserName.Length >= 2
                ? CurrentUserName[..2].ToUpper()
                : CurrentUserName[..1].ToUpper();
        }
    }

    private void OpenSystemModal()
    {
        showSystemModal = true;
        showNotifications = false;
    }

    private void CloseSystemModal()
    {
        showSystemModal = false;
    }

    private void ToggleNotifications()
    {
        if (!UserState.CanSeeNotifications)
            return;

        showNotifications = !showNotifications;
        showSystemModal = false;
    }

    private void GoToNewRequest()
    {
        Navigation.NavigateTo("/repair-requests");
    }

    private void GoToRequests()
    {
        showNotifications = false;
        Navigation.NavigateTo("/repair-requests");
    }
}
