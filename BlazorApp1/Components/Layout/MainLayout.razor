@inherits LayoutComponentBase
@implements IDisposable

@using Microsoft.AspNetCore.Components.Web
@using MyBlazorSite.Data

@inject NavigationManager Navigation
@inject DashboardStatsService StatsService
@inject DashboardStatsNotifier StatsNotifier
@inject AppUserState UserState

<style>
    html,
    body {
        margin: 0;
        min-height: 100%;
        background: #071326;
        color: #f4f7ff;
        font-family: "Segoe UI", Arial, sans-serif;
    }

    a {
        text-decoration: none;
    }

    .app-shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 290px minmax(0, 1fr);
        background: #071326;
        color: #f4f7ff;
    }

    .app-sidebar {
        min-height: 100vh;
        padding: 24px 18px;
        background: linear-gradient(180deg, #081a35, #061226);
        border-right: 1px solid rgba(80, 140, 255, 0.25);
        box-shadow: 8px 0 35px rgba(0, 0, 0, 0.35);
        position: sticky;
        top: 0;
    }

    .brand-block {
        display: flex;
        gap: 14px;
        align-items: center;
        margin-bottom: 28px;
        padding-bottom: 22px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .brand-icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #0d6efd, #6f42c1);
        box-shadow: 0 0 24px rgba(13, 110, 253, 0.45);
    }

    .brand-title {
        font-size: 21px;
        font-weight: 800;
        color: #ffffff;
    }

    .brand-subtitle {
        color: #8fa6c8;
        font-size: 13px;
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 8px;
    }

    .nav-item {
        display: flex !important;
        align-items: center;
        gap: 12px;
        min-height: 50px;
        padding: 0 14px;
        border-radius: 14px;
        color: #c8d7f2 !important;
        text-decoration: none !important;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(120, 160, 255, 0.16);
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .nav-item:hover,
        .nav-item.active {
            transform: translateX(2px);
            background: linear-gradient(135deg, rgba(13, 110, 253, 0.35), rgba(111, 66, 193, 0.32));
            border-color: rgba(80, 160, 255, 0.75);
            color: #ffffff !important;
            box-shadow: 0 0 24px rgba(13, 110, 253, 0.25);
        }

    .nav-danger {
        color: #ff9bad !important;
    }

    .nav-beta {
        margin-left: auto;
        font-size: 11px;
        padding: 3px 7px;
        border-radius: 999px;
        background: rgba(111, 66, 193, 0.25);
        border: 1px solid rgba(111, 66, 193, 0.55);
    }

    .sidebar-footer {
        margin-top: 40px;
        display: grid;
        gap: 14px;
    }

    .system-card,
    .admin-card {
        padding: 15px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.055);
        border: 1px solid rgba(120, 160, 255, 0.16);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }

    .system-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        color: #ffffff;
    }

    .status-dot {
        width: 10px;
        height: 10px;
        display: inline-block;
        border-radius: 50%;
        background: #32d583;
        box-shadow: 0 0 14px rgba(50, 213, 131, 0.8);
    }

    .admin-card {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .admin-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #0d6efd, #6f42c1);
        font-weight: 800;
        color: #ffffff;
    }

        .admin-avatar.small {
            width: 34px;
            height: 34px;
            font-size: 13px;
        }

    .admin-name {
        color: #ffffff;
        font-weight: 700;
    }

    .admin-email,
    .system-date,
    .version-text,
    .online-text {
        color: #8fa6c8;
        font-size: 13px;
    }

    .version-text {
        padding-left: 4px;
    }

    .app-main {
        min-width: 0;
        padding: 18px 34px 34px;
    }

    .app-topbar {
        height: 58px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 16px;
    }

    .topbar-search {
        width: 520px;
        max-width: 100%;
        min-width: 320px;
        height: 44px;
        padding: 0 14px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(255, 255, 255, 0.055);
        border: 1px solid rgba(120, 160, 255, 0.18);
    }

        .topbar-search input {
            width: 100%;
            background: transparent;
            border: 0;
            outline: 0;
            color: #fff;
        }

            .topbar-search input::placeholder {
                color: #8fa6c8;
            }

        .topbar-search kbd {
            white-space: nowrap;
            min-width: 52px;
            text-align: center;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            padding: 4px 8px;
            border-radius: 8px;
            background: rgba(255,255,255,0.08);
            color: #d8e8ff;
            font-size: 12px;
            line-height: 1;
        }

    .topbar-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .topbar-button,
    .new-order-button {
        height: 42px;
        border-radius: 12px;
        border: 1px solid rgba(120, 160, 255, 0.2);
        background: rgba(255, 255, 255, 0.055);
        color: #fff;
        font-weight: 700;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-width: 110px;
        white-space: nowrap;
        box-shadow: 0 8px 22px rgba(0,0,0,0.18);
        position: relative;
    }

    .new-order-button {
        background: linear-gradient(135deg, #0d6efd, #6f42c1);
        border-color: rgba(111, 66, 193, 0.7);
    }

    .notification-badge {
        position: absolute;
        top: -7px;
        right: -7px;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        border-radius: 999px;
        background: #ff4d6d;
        color: #fff;
        font-size: 11px;
        display: grid;
        place-items: center;
    }

    .topbar-user {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 170px;
    }

    .page-hero {
        position: relative;
        min-height: 145px;
        border-radius: 26px;
        margin-bottom: 22px;
        overflow: hidden;
        background: linear-gradient(90deg, rgba(5, 15, 34, 0.92), rgba(5, 15, 34, 0.45)), url("/images/garage-bg.jpg") center / cover no-repeat;
        border: 1px solid rgba(120, 160, 255, 0.18);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
    }

    .page-hero-content {
        position: relative;
        z-index: 1;
        padding: 22px 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
    }

    .page-hero h1 {
        margin: 0;
        font-size: 38px;
        line-height: 1.05;
        font-weight: 850;
        color: #ffffff;
    }

    .page-hero p {
        color: #c9d8f5;
        max-width: 560px;
        font-size: 16px;
        line-height: 1.45;
        margin-top: 10px;
    }

    .hero-stats {
        display: flex;
        gap: 14px;
    }

    .hero-stat-card {
        width: 155px;
        min-height: 92px;
        padding: 15px;
        border-radius: 18px;
        background: rgba(6, 19, 38, 0.72);
        border: 1px solid rgba(120, 160, 255, 0.18);
        backdrop-filter: blur(8px);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }

    .stat-label {
        color: #8fa6c8;
        font-size: 13px;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 850;
        color: #ffffff;
    }

    .stat-positive {
        color: #32d583;
        font-size: 12px;
    }

    .content-surface {
        min-width: 0;
    }

    .card {
        background: rgba(12, 31, 60, 0.78) !important;
        color: #f4f7ff !important;
        border: 1px solid rgba(120, 160, 255, 0.18) !important;
        border-radius: 22px !important;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35) !important;
        backdrop-filter: blur(10px);
    }

    .card-header {
        background: rgba(13, 110, 253, 0.12) !important;
        border-bottom: 1px solid rgba(120, 160, 255, 0.18) !important;
        border-radius: 22px 22px 0 0 !important;
    }

    .form-label {
        color: #d7e3ff;
        font-weight: 700;
    }

    .form-control,
    .form-select {
        background-color: rgba(4, 15, 32, 0.78) !important;
        color: #f4f7ff !important;
        border: 1px solid rgba(120, 160, 255, 0.22) !important;
        border-radius: 12px !important;
    }

        .form-control::placeholder {
            color: #8fa6c8;
        }

        .form-select option {
            background: #0b1730 !important;
            color: #f4f7ff !important;
        }

            .form-select option:checked {
                background: #0d6efd !important;
                color: #ffffff !important;
            }

    .table {
        color: #f4f7ff !important;
        --bs-table-color: #f4f7ff;
        --bs-table-bg: transparent;
        --bs-table-striped-bg: rgba(255, 255, 255, 0.03);
        --bs-table-hover-bg: rgba(13, 110, 253, 0.09);
    }

        .table thead th {
            background: rgba(6, 19, 38, 0.9) !important;
            color: #e9f2ff !important;
        }

        .table td,
        .table th {
            border-color: rgba(120, 160, 255, 0.15) !important;
        }

    .alert-secondary {
        background: rgba(13, 110, 253, 0.12) !important;
        color: #e9f2ff !important;
        border-color: rgba(120, 160, 255, 0.18) !important;
    }

    .alert-info {
        background: rgba(13, 110, 253, 0.12) !important;
        color: #d8e8ff !important;
        border-color: rgba(120, 160, 255, 0.18) !important;
    }

    .btn-primary {
        background: linear-gradient(135deg, #0d6efd, #6f42c1) !important;
        border-color: rgba(111, 66, 193, 0.7) !important;
    }

    .btn-outline-secondary,
    .btn-outline-primary,
    .btn-outline-dark {
        color: #d8e8ff !important;
        border-color: rgba(120, 160, 255, 0.28) !important;
    }

    .btn-danger {
        background: rgba(255, 77, 109, 0.18) !important;
        border-color: rgba(255, 77, 109, 0.45) !important;
        color: #ffb8c5 !important;
    }

    /* HOME PAGE */

    .home-page {
        width: 100%;
        max-width: none;
        margin: 0;
        display: grid;
        gap: 22px;
    }

    .home-welcome-card {
        border-radius: 24px;
        background: linear-gradient(135deg, rgba(31, 42, 58, 0.92), rgba(18, 27, 43, 0.94));
        border: 1px solid rgba(120, 160, 255, 0.14);
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.25);
        padding: 34px 48px;
    }

    .home-welcome-content {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .welcome-icon {
        width: 70px;
        height: 70px;
        border-radius: 22px;
        display: grid;
        place-items: center;
        font-size: 34px;
        background: linear-gradient(135deg, rgba(13, 110, 253, 0.35), rgba(111, 66, 193, 0.35));
        border: 1px solid rgba(120, 160, 255, 0.3);
        box-shadow: 0 0 28px rgba(13, 110, 253, 0.25);
    }

    .home-welcome-card h2 {
        margin: 0;
        font-size: 42px;
        line-height: 1.1;
        font-weight: 850;
        color: #ffffff;
    }

    .home-welcome-card p {
        margin: 16px 0 0;
        color: #d3def7;
        font-size: 18px;
    }

    .welcome-actions {
        margin-top: 24px;
        display: flex;
        gap: 16px;
    }

    .home-primary-button,
    .home-warning-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 13px;
        font-weight: 800;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .home-primary-button {
        color: #ffffff;
        background: linear-gradient(135deg, #16a34a, #22c55e);
        box-shadow: 0 12px 24px rgba(34, 197, 94, 0.18);
    }

    .home-warning-button {
        color: #111827;
        background: linear-gradient(135deg, #fbbf24, #facc15);
        box-shadow: 0 12px 24px rgba(251, 191, 36, 0.18);
    }

        .home-primary-button:hover,
        .home-warning-button:hover,
        .home-shortcut-card:hover {
            transform: translateY(-2px);
        }

    .home-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(220px, 1fr));
        gap: 22px;
    }

    .home-stat-card,
    .home-average-card,
    .home-chart-card,
    .home-shortcut-card,
    .home-features-card {
        background: rgba(24, 40, 68, 0.9);
        border: 1px solid rgba(120, 160, 255, 0.14);
        border-radius: 20px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
    }

    .home-stat-card {
        min-height: 104px;
        padding: 22px;
        text-align: center;
        display: grid;
        place-items: center;
    }

    .home-stat-label {
        color: #9fb3d9;
        font-size: 15px;
    }

    .home-stat-card strong {
        display: block;
        margin-top: 8px;
        color: #ffffff;
        font-size: 32px;
        line-height: 1;
    }

    .home-average-card {
        padding: 24px;
    }

        .home-average-card strong {
            display: block;
            margin-top: 8px;
            font-size: 32px;
            color: #ffffff;
        }

    .home-chart-card {
        padding: 22px;
    }

    .section-header h3 {
        margin: 0;
        color: #ffffff;
        font-size: 24px;
        font-weight: 800;
    }

    .section-header p {
        margin: 6px 0 0;
        color: #9fb3d9;
    }

    .chart-shell {
        margin-top: 18px;
        height: 330px;
        padding: 12px;
        border-radius: 18px;
        background: rgba(7, 19, 38, 0.92);
        border: 1px solid rgba(120, 160, 255, 0.14);
        overflow: hidden;
    }

        .chart-shell canvas,
        #statusChart {
            background: transparent !important;
            border-radius: 16px;
        }

    .home-shortcuts-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 22px;
    }

    .home-shortcut-card {
        min-height: 150px;
        padding: 24px;
        color: #ffffff;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .shortcut-icon {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        background: rgba(13, 110, 253, 0.18);
        border: 1px solid rgba(120, 160, 255, 0.22);
        margin-bottom: 16px;
        font-size: 24px;
    }

    .home-shortcut-card h4 {
        margin: 0;
        font-size: 18px;
        font-weight: 800;
    }

    .home-shortcut-card p {
        margin: 8px 0 0;
        color: #9fb3d9;
        font-size: 14px;
        line-height: 1.45;
    }

    .home-features-card {
        padding: 24px;
    }

        .home-features-card h3 {
            margin: 0 0 18px;
            font-size: 24px;
            font-weight: 800;
        }

    .features-list {
        display: grid;
        gap: 12px;
    }

        .features-list div {
            padding: 12px 14px;
            border-radius: 12px;
            background: rgba(7, 19, 38, 0.42);
            border: 1px solid rgba(120, 160, 255, 0.1);
            color: #d8e8ff;
        }

    /* REPAIR REQUESTS PAGE */

    .repair-page {
        width: 100%;
        display: grid;
        gap: 24px;
    }

    .repair-workspace,
    .requests-section {
        background: rgba(24, 40, 68, 0.9);
        border: 1px solid rgba(120, 160, 255, 0.14);
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
    }

    .repair-section-header,
    .requests-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 22px;
        margin-bottom: 22px;
    }

    .section-kicker {
        color: #6fb4ff;
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .repair-section-header h2,
    .requests-header h2 {
        margin: 4px 0 0;
        color: #ffffff;
        font-size: 28px;
        font-weight: 850;
    }

    .repair-section-header p {
        margin: 8px 0 0;
        color: #9fb3d9;
    }

    .repair-step-pill {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 42px;
        padding: 0 16px;
        border-radius: 999px;
        background: rgba(13, 110, 253, 0.16);
        border: 1px solid rgba(120, 160, 255, 0.24);
        color: #d8e8ff;
        font-weight: 800;
        white-space: nowrap;
    }

        .repair-step-pill span {
            width: 25px;
            height: 25px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg, #0d6efd, #6f42c1);
        }

    .repair-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 370px;
        gap: 22px;
        align-items: start;
    }

    .repair-main-card,
    .repair-summary-card {
        background: rgba(7, 19, 38, 0.62);
        border: 1px solid rgba(120, 160, 255, 0.14);
        border-radius: 22px;
        padding: 22px;
    }

    .repair-card-title,
    .summary-title {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
    }

        .repair-card-title span,
        .summary-title span {
            width: 38px;
            height: 38px;
            display: grid;
            place-items: center;
            border-radius: 14px;
            background: rgba(13, 110, 253, 0.18);
            border: 1px solid rgba(120, 160, 255, 0.22);
        }

        .repair-card-title h3,
        .summary-title h3 {
            margin: 0;
            color: #ffffff;
            font-size: 20px;
            font-weight: 850;
        }

        .summary-title p {
            margin: 2px 0 0;
            color: #9fb3d9;
            font-size: 13px;
        }

    .repair-form-grid {
        display: grid;
        gap: 18px;
    }

        .repair-form-grid.three {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .repair-form-grid.four {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }

    .repair-divider {
        height: 1px;
        margin: 24px 0;
        background: rgba(120, 160, 255, 0.14);
    }

    .damage-type-row {
        margin-top: 18px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .damage-chip {
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(120, 160, 255, 0.18);
        background: rgba(255, 255, 255, 0.045);
        color: #d8e8ff;
        font-weight: 700;
    }

    .upload-panel {
        display: flex;
        gap: 18px;
        padding: 22px;
        border-radius: 20px;
        border: 1px dashed rgba(120, 160, 255, 0.35);
        background: rgba(13, 110, 253, 0.08);
    }

    .upload-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: rgba(13, 110, 253, 0.2);
        font-size: 26px;
    }

    .upload-content {
        display: grid;
        gap: 8px;
        flex: 1;
    }

        .upload-content strong {
            color: #ffffff;
        }

        .upload-content span {
            color: #9fb3d9;
        }

    .repair-summary-card {
        position: sticky;
        top: 18px;
    }

    .summary-price {
        margin: 20px 0;
        color: #32d583;
        font-size: 42px;
        font-weight: 900;
        letter-spacing: -0.04em;
    }

    .summary-breakdown {
        display: grid;
        gap: 12px;
    }

        .summary-breakdown div,
        .summary-empty,
        .summary-hint {
            padding: 13px 14px;
            border-radius: 14px;
            background: rgba(24, 40, 68, 0.72);
            border: 1px solid rgba(120, 160, 255, 0.1);
        }

        .summary-breakdown div {
            display: flex;
            justify-content: space-between;
            gap: 12px;
        }

        .summary-breakdown span,
        .summary-empty,
        .summary-hint span {
            color: #9fb3d9;
        }

        .summary-breakdown strong {
            color: #ffffff;
        }

    .summary-total-row {
        border-color: rgba(50, 213, 131, 0.28) !important;
    }

        .summary-total-row strong {
            color: #32d583;
        }

    .summary-error {
        margin-top: 14px;
        padding: 13px 14px;
        border-radius: 14px;
        color: #ffd7df;
        background: rgba(255, 77, 109, 0.12);
        border: 1px solid rgba(255, 77, 109, 0.28);
    }

    .summary-actions {
        display: grid;
        gap: 12px;
        margin-top: 18px;
    }

    .summary-hint {
        margin-top: 18px;
        display: grid;
        gap: 4px;
    }

        .summary-hint strong {
            color: #ffffff;
        }

    .requests-filters {
        display: grid;
        grid-template-columns: minmax(280px, 1fr) 180px auto auto;
