    place-items: center;
    color: #bfdbfe;
    background:
        linear-gradient(135deg, rgba(37, 99, 235, 0.26), rgba(124, 58, 237, 0.18)),
        rgba(13, 110, 253, 0.12);
    border: 1px solid rgba(147, 197, 253, 0.22);
}

.system-info-icon svg {
    width: 22px;
    height: 22px;
    display: block;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
}

    .theme-toggle-button {
        height: 42px;
        min-width: 128px;
        padding: 0 14px;
        border-radius: 12px;
        border: 1px solid rgba(120, 160, 255, 0.20);
        background: rgba(255, 255, 255, 0.055);
        color: #ffffff;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        white-space: nowrap;
        box-shadow: 0 8px 22px rgba(0,0,0,0.18);
        transition: 0.18s ease;
    }

        .theme-toggle-button:hover {
            transform: translateY(-1px);
            border-color: rgba(80, 160, 255, 0.70);
            background: rgba(13, 110, 253, 0.16);
        }

    .theme-toggle-icon {
        width: 20px;
        height: 20px;
        display: inline-grid;
        place-items: center;
    }

        .theme-toggle-icon svg {
            width: 19px;
            height: 19px;
            display: block;
            stroke: currentColor;
            fill: none;
            stroke-width: 2.2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .theme-toggle-label {
        color: #ffffff;
        font-size: 13px;
    }



