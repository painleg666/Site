@code {
    private const string ThemeStorageKey = "autoestimate-theme";
    private bool isLightTheme;

    private DashboardStats stats = new();

    private bool showSystemModal = false;
    private bool showNotifications = false;
    

    private int NotificationCount =>
        UserState.CanSeeNotifications
            ? stats.NewRequestsCount
            : 0;


    private DateTime currentTime = DateTime.Now;
private PeriodicTimer? clockTimer;
private CancellationTokenSource clockCts = new();

protected override void OnInitialized()
{
    _ = RunClockAsync();
}

private async Task RunClockAsync()
{
    clockTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));

    try
    {
        while (await clockTimer.WaitForNextTickAsync(clockCts.Token))
        {
            currentTime = DateTime.Now;
            await InvokeAsync(StateHasChanged);
        }
    }
    catch (OperationCanceledException)
    {
        // Нормальное завершение при выходе со страницы.
    }
}

public void Dispose()
{
    clockCts.Cancel();
    clockTimer?.Dispose();
    clockCts.Dispose();
}
    protected override async Task OnInitializedAsync()
    {
        stats = await StatsService.GetStatsAsync();
        StatsNotifier.OnChange += RefreshStatsAsync;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var savedTheme = await JS.InvokeAsync<string?>("localStorage.getItem", ThemeStorageKey);

        isLightTheme = savedTheme == "light";

        await ApplyThemeClassAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshStatsAsync()
    {
        stats = await StatsService.GetStatsAsync();
        await InvokeAsync(StateHasChanged);
    }


    private async Task ToggleThemeAsync()
    {
        isLightTheme = !isLightTheme;

        var theme = isLightTheme ? "light" : "dark";

        await JS.InvokeVoidAsync("localStorage.setItem", ThemeStorageKey, theme);
        await ApplyThemeClassAsync();
    }

    private async Task ApplyThemeClassAsync()
    {
        var addClass = isLightTheme ? "light-theme" : "dark-theme";
        var removeClass = isLightTheme ? "dark-theme" : "light-theme";

        var script =
            $"document.body.classList.remove('{removeClass}');" +
            $"document.body.classList.add('{addClass}');" +
            $"document.documentElement.classList.remove('{removeClass}');" +
            $"document.documentElement.classList.add('{addClass}');";

        await JS.InvokeVoidAsync("eval", script);
    }

    private string CurrentUserName =>
        string.IsNullOrWhiteSpace(UserState.UserName)
            ? "Гость"
            : UserState.UserName;

    private string CurrentUserEmail =>
        string.IsNullOrWhiteSpace(UserState.Email)
            ? "Не авторизован"
            : UserState.Email;

    private string CurrentUserRole =>
        string.IsNullOrWhiteSpace(UserState.Role)
            ? "Гость"
            : UserState.Role;

    private string CurrentUserInitials
    {
        get
        {
            if (string.IsNullOrWhiteSpace(CurrentUserName))
                return "U";

            var parts = CurrentUserName.Split(' ', StringSplitOptions.RemoveEmptyEntries);

            if (parts.Length >= 2)
                return $"{parts[0][0]}{parts[1][0]}".ToUpper();

            return CurrentUserName.Length >= 2
                ? CurrentUserName[..2].ToUpper()
                : CurrentUserName[..1].ToUpper();
        }
    }

    private void OpenSystemModal()
    {
        showSystemModal = true;
        showNotifications = false;
    }

    private void CloseSystemModal()
    {
        showSystemModal = false;
    }

    private void ToggleNotifications()
    {
        if (!UserState.CanSeeNotifications)
            return;

        showNotifications = !showNotifications;
        showSystemModal = false;
    }

    private void GoToNewRequest()
    {
        showNotifications = false;
        showSystemModal = false;

        Navigation.NavigateTo("/repair-requests");
    }

    private void GoToRequests()
    {
        showNotifications = false;
        Navigation.NavigateTo("/repair-requests");
    }
}
