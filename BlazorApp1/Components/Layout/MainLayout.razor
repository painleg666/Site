/* REAL SVG DAMAGE MAP */

.real-blueprint {
    min-height: 560px;
    display: grid;
    place-items: center;
    border-radius: 18px;
    background:
        linear-gradient(rgba(120, 160, 255, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(120, 160, 255, 0.05) 1px, transparent 1px);
    background-size: 32px 32px;
    border: 1px solid rgba(120, 160, 255, 0.1);
    overflow: hidden;
}

.vehicle-svg {
    width: 100%;
    max-width: 420px;
    height: auto;
    filter: drop-shadow(0 0 18px rgba(13, 110, 253, 0.14));
}

.vehicle-shell {
    fill: url(#bodyGlow);
    stroke: rgba(214, 232, 255, 0.58);
    stroke-width: 2.4;
}

.vehicle-glass {
    fill: rgba(180, 215, 255, 0.08);
    stroke: rgba(214, 232, 255, 0.25);
    stroke-width: 1.2;
}

.vehicle-axis {
    stroke: rgba(214, 232, 255, 0.12);
    stroke-width: 1.2;
    stroke-dasharray: 6 8;
}

.svg-zone {
    cursor: pointer;
    transition: 0.18s ease;
    stroke-width: 1.2;
}

.svg-zone:hover {
    filter: brightness(1.15);
    transform-box: fill-box;
    transform-origin: center;
}

.svg-zone.active {
    stroke: #32d583 !important;
    stroke-width: 2.2;
    filter: drop-shadow(0 0 10px rgba(50, 213, 131, 0.34));
}

.zone-front {
    fill: rgba(239, 68, 68, 0.22);
    stroke: rgba(239, 68, 68, 0.52);
}

.zone-light {
    fill: rgba(250, 204, 21, 0.22);
    stroke: rgba(250, 204, 21, 0.55);
}

.zone-hood {
    fill: rgba(139, 92, 246, 0.18);
    stroke: rgba(139, 92, 246, 0.48);
}

.zone-fender {
    fill: rgba(30, 139, 255, 0.17);
    stroke: rgba(30, 139, 255, 0.48);
}

.zone-door {
    fill: rgba(34, 197, 94, 0.16);
    stroke: rgba(34, 197, 94, 0.46);
}

.zone-sill {
    fill: rgba(20, 184, 166, 0.18);
    stroke: rgba(20, 184, 166, 0.46);
}

.zone-trunk {
    fill: rgba(249, 115, 22, 0.18);
    stroke: rgba(249, 115, 22, 0.52);
}

.zone-rear {
    fill: rgba(251, 113, 133, 0.18);
    stroke: rgba(251, 113, 133, 0.52);
}

.svg-zone-label {
    fill: #e9f2ff;
    font-size: 13px;
    font-weight: 800;
    text-anchor: middle;
    pointer-events: none;
}

.svg-zone-label.small {
    font-size: 12px;
}

