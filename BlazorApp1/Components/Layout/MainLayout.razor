/* REAL SVG DAMAGE MAP */

.real-blueprint {
    min-height: 560px;
    display: grid;
    place-items: center;
    border-radius: 18px;
    background:
        linear-gradient(rgba(120, 160, 255, 0.05) 1px, transparent 1px),
